{%- comment -%}
  One offer, one place. Pulls from theme settings so the same promise
  shows in the announcement bar, PDP, and cart progress bar.
{%- endcomment -%}
<div class="announcement">
  {%- if section.settings.custom_text != blank -%}
    {{ section.settings.custom_text }}
  {%- else -%}
    <strong>{{ settings.shipping_promise }}</strong> &nbsp;·&nbsp; Engraved to order, ships in {{ settings.production_days }} business days
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "custom_text",
      "label": "Override text (optional)",
      "info": "Leave blank to use the global shipping promise from Theme settings. Only override for short campaigns, and remove it after."
    }
  ]
}
{% endschema %}
