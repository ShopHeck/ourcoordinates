<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="coord-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 style="margin:0">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}">View all</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- liquid
        assign shown = 0
        for product in section.settings.collection.products limit: 24
          if shown >= section.settings.limit
            break
          endif
          if section.settings.hide_sold_out and product.available == false
            continue
          endif
          render 'product-card', card_product: product
          assign shown = shown | plus: 1
        endfor
      -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Most-gifted this month" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 8 },
    {
      "type": "checkbox", "id": "hide_sold_out", "label": "Hide sold-out products", "default": true,
      "info": "Keeps your homepage selling. Sold-out items stay visible on collection pages."
    }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
