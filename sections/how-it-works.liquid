{%- comment -%}
  HOW IT WORKS — bespoke section for OurCoordinates.
  Five steps, each with a hand-built inline SVG explainer in the
  reticle / topo / engraved-metal visual language. Zero image requests.
{%- endcomment -%}

<section class="hiw-hero">
  <div class="hiw-hero__grid" aria-hidden="true"></div>
  <div class="page-width">
    <p class="coord-eyebrow" style="justify-content:center;color:var(--c-gold)">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="hiw-hero__sub">{{ section.settings.subheading }}</p>
    <a class="btn" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">{{ section.settings.cta_label }}</a>
  </div>
  <div class="hiw-hero__route" aria-hidden="true">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" fill="none">
      <path d="M0 80 C 200 20, 360 100, 560 60 S 920 10, 1200 70" stroke="#B6976A" stroke-width="2" stroke-dasharray="2 8" stroke-linecap="round"/>
    </svg>
  </div>
</section>

<div class="hiw">
  <div class="page-width">
    <ol class="hiw__steps">
      {%- assign step_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_count = step_count | plus: 1 -%}
          {%- assign is_even = step_count | modulo: 2 -%}
          <li class="hiw-step{% if is_even == 0 %} hiw-step--flip{% endif %}" {{ block.shopify_attributes }}>
            <div class="hiw-step__text">
              <span class="hiw-step__num">{% if step_count < 10 %}0{% endif %}{{ step_count }}</span>
              <h2>{{ block.settings.title }}</h2>
              <p>{{ block.settings.text }}</p>
            </div>
            <div class="hiw-step__viz">
              <div class="hiw-step__image-wrapper">
                {%- if block.settings.image != blank -%}
                  <img class="hiw-step__image"
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                    width="600"
                    height="450">
                {%- else -%}
                  {%- capture fallback_img -%}how-it-works-step-{{ step_count }}.png{%- endcapture -%}
                  <img class="hiw-step__image"
                    src="{{ fallback_img | asset_url }}"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                    width="600"
                    height="450">
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ol>
  </div>
</div>

{%- comment -%} ============ TRUST RECAP ============ {%- endcomment -%}
<section class="section hiw-recap">
  <div class="page-width">
    <p class="coord-eyebrow" style="justify-content:center">{{ section.settings.recap_eyebrow }}</p>
    <h2 style="text-align:center">{{ section.settings.recap_heading }}</h2>
    <div class="hiw-recap__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'promise' -%}
          <div class="hiw-recap__item" {{ block.shopify_attributes }}>
            <span class="hiw-recap__coord">◆</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div style="text-align:center;margin-top:40px">
      <a class="btn" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

{%- comment -%} ============ FAQ ============ {%- endcomment -%}
{%- if section.blocks.size > 0 -%}
<section class="section hiw-faq">
  <div class="page-width page-narrow">
    <p class="coord-eyebrow">{{ section.settings.faq_eyebrow }}</p>
    <h2>{{ section.settings.faq_heading }}</h2>
    <div class="pdp__accordions" style="margin-top:24px">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <details {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <div class="accordion-body rte">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Place to keepsake in four steps" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How it works" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From the spot that matters to a piece you'll wear forever — here's exactly what happens, start to finish." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Start with your coordinates" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "header", "content": "Promises recap" },
    { "type": "text", "id": "recap_eyebrow", "label": "Eyebrow", "default": "Why people trust us with it" },
    { "type": "text", "id": "recap_heading", "label": "Heading", "default": "No guesswork. No surprises." },
    { "type": "header", "content": "FAQ" },
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow", "default": "Before you ask" },
    { "type": "text", "id": "faq_heading", "label": "Heading", "default": "Common questions" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "promise",
      "name": "Promise",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Photo proof first" },
        { "type": "text", "id": "text", "label": "Text", "default": "You approve the real engraving before it ships." }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What if I don't know the coordinates?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>You don't need to. Just search the place or drop a pin on the map — we read the exact coordinates for you.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step", "settings": { "title": "Find your coordinates", "text": "Search any place by name or drop a pin on our interactive map. We'll automatically translate it into precise latitude and longitude coordinates." } },
        { "type": "step", "settings": { "title": "Choose your jewelry", "text": "Select your style, precious metal color, and coordinates layout. Customize up to four sides on our signature coordinate bars." } },
        { "type": "step", "settings": { "title": "Crafted & engraved", "text": "Each piece is individually engraved with laser precision at our workbench. We send you a photo proof of the actual engraving to approve before shipping." } },
        { "type": "step", "settings": { "title": "Cherished & delivered", "text": "Unbox a beautifully packaged keepsake, complete with an optional handwritten gift card. Wear your special memory close to you, forever." } },
        { "type": "promise", "settings": { "title": "Made to order", "text": "Every piece is engraved for one person — yours." } },
        { "type": "promise", "settings": { "title": "Photo proof first", "text": "You approve the real engraving before it ships." } },
        { "type": "promise", "settings": { "title": "30-day guarantee", "text": "Not right? We remake it or refund you." } },
        { "type": "faq", "settings": { "question": "What if I don't know the exact coordinates?", "answer": "<p>You don't need to. Search the place by name or drop a pin on the map and we read the precise latitude and longitude for you.</p>" } },
