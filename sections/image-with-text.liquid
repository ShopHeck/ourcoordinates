<section class="section">
  <div class="page-width">
    <div class="img-text {% if section.settings.flip %}img-text--flip{% endif %}">
      <div class="img-text__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="{{ section.settings.image.width | at_most: 1000 }}" height="{{ section.settings.image.width | at_most: 1000 | divided_by: section.settings.image.aspect_ratio | round }}">
        {%- endif -%}
      </div>
      <div>
        <p class="coord-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        <div class="rte">{{ section.settings.text }}</div>
        {%- if section.settings.button_label != blank -%}
          <a class="btn btn--ghost" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "flip", "label": "Image on the right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick the place. We engrave the rest." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Tell us your spot — a first date, a hometown, a summit. We convert it to exact coordinates, engrave it by laser, and send you a photo proof before it ships.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
