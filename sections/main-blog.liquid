<section class="section">
  <div class="page-width">
    <p class="coord-eyebrow">Journal</p>
    <h1>{{ blog.title }}</h1>
    {%- paginate blog.articles by 12 -%}
      <div class="product-grid" style="margin-top:28px">
        {%- for article in blog.articles -%}
          <a class="product-card" href="{{ article.url }}">
            <div class="product-card__media">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy" width="{{ article.image.width | at_most: 600 }}" height="{{ article.image.width | at_most: 600 | divided_by: article.image.aspect_ratio | round }}">
              {%- endif -%}
            </div>
            <p class="product-card__title">{{ article.title }}</p>
            <p class="product-card__price">{{ article.published_at | date: '%b %-d, %Y' }}</p>
          </a>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <nav class="pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">‹</a>{%- endif -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">›</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>
{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
