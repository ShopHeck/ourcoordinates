<section class="section">
  <div class="page-width">
    <div class="collection-head">
      <p class="coord-eyebrow">Collection</p>
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="rte" style="max-width:62ch">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- paginate collection.products by 24 -%}
      <div class="product-grid">
        {%- for product in collection.products -%}
          {%- render 'product-card', card_product: product -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">‹</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="current">{{ part.title }}</span>
            {%- else -%}
              <span>{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">›</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{ "name": "Collection page", "settings": [] }
{% endschema %}
