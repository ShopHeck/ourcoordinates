<section class="section">
  <div class="page-width">
    <h1>Collections</h1>
    <div class="product-grid" style="margin-top:28px">
      {%- for collection in collections -%}
        <a class="product-card" href="{{ collection.url }}">
          <div class="product-card__media">
            {%- if collection.featured_image -%}
              <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <p class="product-card__title">{{ collection.title }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{ "name": "Collections list", "settings": [] }
{% endschema %}
