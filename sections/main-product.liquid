{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign ships_by = 'now' | date: '%s' | plus: 0
  assign prod_seconds = settings.production_days | times: 86400
  assign transit_seconds = settings.transit_days | times: 86400
  assign delivery_low = ships_by | plus: prod_seconds | plus: transit_seconds
  assign delivery_high = delivery_low | plus: 259200
  assign preview_type = section.settings.preview_type | default: 'horizontal-bar'
-%}

<section class="section" data-product data-preview-type="{{ preview_type }}">
  <div class="page-width pdp">

    {%- comment -%} ---------- GALLERY ---------- {%- endcomment -%}
    <div class="pdp__gallery">
      <div class="pdp__main-image">
        <img data-main-image
             src="{{ product.featured_image | image_url: width: 1200 }}"
             srcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
             sizes="(max-width: 880px) 100vw, min(52vw, 640px)"
             alt="{{ product.featured_image.alt | escape }}" width="1200" height="1200"
             fetchpriority="high" decoding="async">
      </div>
      {%- if product.images.size > 1 -%}
        <div class="pdp__thumbs">
          {%- for image in product.images limit: 12 -%}
            <button type="button" data-thumb data-full="{{ image | image_url: width: 1200 }}"
                    data-full-srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w"
                    {% if forloop.first %}aria-current="true"{% endif %}
                    aria-label="View image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape }}" loading="lazy" width="160" height="160">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ---------- BUY BOX ---------- {%- endcomment -%}
    <div data-buy-box>
      <p class="pdp__vendor">{{ product.vendor }}</p>
      <h1 class="pdp__title">{{ product.title }}</h1>

      {%- comment -%}
        Review summary. 'app' renders the Judge.me preview badge (stars +
        count pulled from real reviews — the app embed fills the div).
        'link' is the no-app fallback: a plain link to the reviews page.
      {%- endcomment -%}
      {%- if section.settings.review_style == 'app' -%}
        <div class="pdp__reviews">
          <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}"></div>
        </div>
      {%- elsif section.settings.review_style == 'link' -%}
        <p class="pdp__reviews">
          <a href="/pages/reviews">Read verified customer reviews</a>
        </p>
      {%- endif -%}

      <p class="pdp__price" data-price>
        {{ current_variant.price | money }}
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s>{{ current_variant.compare_at_price | money }}</s>
        {%- endif -%}
      </p>

      <p class="pdp__shipline">
        <strong>{{ settings.shipping_promise }}.</strong>
        {%- if section.settings.show_engraving -%}
          Engraved to order — ships in {{ settings.production_days }} business days,
        {%- else -%}
          Made to order — ships in {{ settings.production_days }} business days,
        {%- endif -%}
        estimated delivery {{ delivery_low | date: '%b %-d' }}–{{ delivery_high | date: '%b %-d' }}.
      </p>

      {%- comment -%}
        Order-by reminder for the next gifting occasion. Order-by date =
        occasion minus production, transit, and the same 3-day buffer used
        in the delivery estimate. Hides itself once too late or past.
        An unparseable date makes occasion_ts 0, so it fails closed.
      {%- endcomment -%}
      {%- if settings.occasion_label != blank and settings.occasion_date != blank -%}
        {%- liquid
          assign occasion_ts = settings.occasion_date | date: '%s' | plus: 0
          assign lead_seconds = prod_seconds | plus: transit_seconds | plus: 259200
          assign order_by_ts = occasion_ts | minus: lead_seconds
        -%}
        {%- if occasion_ts > ships_by and order_by_ts >= ships_by -%}
          <p class="pdp__occasion">
            <span class="pdp__occasion-dot" aria-hidden="true">◆</span>
            Ordering for {{ settings.occasion_label }}? Order by <strong>{{ order_by_ts | date: '%A, %b %-d' }}</strong> to unwrap it in time.
          </p>
        {%- endif -%}
      {%- endif -%}

      {%- form 'product', product, data-product-form: '' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <fieldset class="swatches option-group" data-option-index="{{ forloop.index0 }}">
              <legend class="buy-step">
                {{ option.name }}
                {%- assign opt_name_down = option.name | downcase -%}
                {%- if opt_name_down == 'engrave' or opt_name_down contains 'side' %} <span>— engraving is free on every side</span>{% endif -%}
              </legend>
              {%- for value in option.values -%}
                <input type="radio" id="opt-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                       name="option-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}"
                       {% if option.selected_value == value %}checked{% endif %}>
                <label for="opt-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}">{{ value }}</label>
              {%- endfor -%}
            </fieldset>
          {%- endfor -%}
        {%- endunless -%}

        {%- comment -%} ========== ENGRAVING PREVIEWS ========== {%- endcomment -%}
        {%- if section.settings.show_engraving -%}

          {%- comment -%}
            Shared brushed-metal gradients. Every preview's .ep__metal fill
            switches between these via CSS when the shopper picks a metal
            variant (data-metal on the section root, set by global.js).
          {%- endcomment -%}
          <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
            <defs>
              <linearGradient id="ep-metal-black" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#3a3a42"/><stop offset="0.5" stop-color="#1c1c24"/><stop offset="1" stop-color="#101016"/>
              </linearGradient>
              <linearGradient id="ep-metal-gold" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#e7cd8f"/><stop offset="0.45" stop-color="#c4a26d"/><stop offset="1" stop-color="#997a4e"/>
              </linearGradient>
              <linearGradient id="ep-metal-rose-gold" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#f0c8b2"/><stop offset="0.45" stop-color="#d49b84"/><stop offset="1" stop-color="#b0765f"/>
              </linearGradient>
              <linearGradient id="ep-metal-silver" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#f0f0f4"/><stop offset="0.45" stop-color="#c9c9d1"/><stop offset="1" stop-color="#a2a2ac"/>
              </linearGradient>
            </defs>
          </svg>

          {%- comment -%} ---- FOUR-SIDED BAR ---- {%- endcomment -%}
          {%- if preview_type == 'four-sided' -%}
            {%- comment -%}
              How many sides can be engraved is a PRODUCT VARIANT whenever a
              variant option value looks like "2 Sides" — the inputs and the
              preview follow the shopper's selection (and its price). The
              manual "How many sides?" picker renders only for products
              without such an option.
            {%- endcomment -%}
            {%- liquid
              assign sides_option = -1
              for option in product.options_with_values
                assign joined_values = option.values | join: ' '
                assign opt_probe = option.name | append: ' ' | append: joined_values | downcase
                if opt_probe contains 'side'
                  assign sides_option = forloop.index0
                  break
                endif
              endfor

              assign initial_sides = 0
              if sides_option >= 0
                assign side_val = current_variant.options[sides_option] | downcase
                if side_val contains '4'
                  assign initial_sides = 4
                elsif side_val contains '3'
                  assign initial_sides = 3
                elsif side_val contains '2'
                  assign initial_sides = 2
                elsif side_val contains '1'
                  assign initial_sides = 1
                endif
              endif
              if initial_sides == 0
                assign initial_sides = 2
                assign sides_source = 'manual'
              else
                assign sides_source = 'variant'
              endif
            -%}

            <div class="engrave-field" data-four-sided-engraving
                 data-sides-source="{{ sides_source }}" data-active-sides="{{ initial_sides }}"
                 data-sides-option="{{ sides_option }}">
              <p class="option-group buy-step" style="margin-bottom:8px">Your engraving</p>

              {%- comment -%} One pendant shown from every engraved side {%- endcomment -%}
              <div class="ep ep--four-sided" aria-hidden="true">
                <div class="ep__chain">
                  <svg viewBox="0 0 300 42" preserveAspectRatio="xMidYMax meet">
                    <path d="M 6,0 L 150,32 L 294,0" fill="none" class="ep__chain-line"/>
                    <circle cx="150" cy="35" r="4.5" fill="none" class="ep__chain-line"/>
                  </svg>
                </div>
                <div class="ep__faces">
                  {%- for i in (1..4) -%}
                    <div class="ep__face" data-face="{{ i }}" data-face-active="{% if i <= initial_sides %}true{% else %}false{% endif %}">
                      <svg viewBox="0 0 44 190" class="ep__face-svg" aria-hidden="true">
                        <rect x="4" y="6" width="36" height="178" rx="3" class="ep__metal"/>
                        <rect x="6.5" y="8.5" width="12" height="173" rx="2.5" class="ep__sheen"/>
                        <rect x="4.7" y="6.7" width="34.6" height="176.6" rx="2.6" class="ep__bevel" fill="none"/>
                        {%- if i <= 2 -%}<circle cx="22" cy="17" r="3" class="ep__hole"/>{%- endif -%}
                        <text x="22" y="{% if i <= 2 %}103{% else %}98{% endif %}" data-four-preview="{{ i }}"
                              class="ep__engrave-text ep__engrave-text--vertical"
                              data-fit="150" data-fit-chars="12" lengthAdjust="spacingAndGlyphs"
                              data-placeholder="{% case i %}{% when 1 %}{{ section.settings.engraving_placeholder | escape }}{% when 2 %}82.6403° W{% else %}· · ·{% endcase %}">
                          {%- case i %}{% when 1 %}{{ section.settings.engraving_placeholder }}{% when 2 %}82.6403° W{% else %}· · ·{% endcase -%}
                        </text>
                      </svg>
                      <span class="ep__face-label">{% case i %}{% when 1 %}Front{% when 2 %}Back{% when 3 %}Left{% when 4 %}Right{% endcase %}</span>
                    </div>
                  {%- endfor -%}
                </div>
                <p class="ep__hint" data-four-hint>Live preview — one pendant, engraved on {{ initial_sides }} side{% if initial_sides != 1 %}s{% endif %}</p>
              </div>

              {%- comment -%} Manual side picker — fallback only {%- endcomment -%}
              {%- if sides_source == 'manual' -%}
                <fieldset class="ep__side-picker option-group" data-side-count-picker>
                  <legend>How many sides?</legend>
                  {%- for n in (1..4) -%}
                    <input type="radio" id="sides-{{ n }}" name="side-count" value="{{ n }}"
                           {% if n == 2 %}checked{% endif %}>
                    <label for="sides-{{ n }}">{{ n }} side{{ n | pluralize: '', 's' }}</label>
                  {%- endfor -%}
                </fieldset>
              {%- endif -%}

              {%- comment -%} Per-side inputs — hidden sides are disabled so they never submit {%- endcomment -%}
              {%- for i in (1..4) -%}
                <div class="ep__side-input" data-side-field="{{ i }}"
                     {% if i > initial_sides %}style="display:none"{% endif %}>
                  <label for="engrave-side-{{ i }}">
                    {% case i %}{% when 1 %}Front{% when 2 %}Back{% when 3 %}Left side{% when 4 %}Right side{% endcase %}
                    {%- if i > 1 %} <span class="ep__side-optional">optional</span>{% endif -%}
                  </label>
                  <input type="text" id="engrave-side-{{ i }}"
                         data-engrave-input-side="{{ i }}"
                         name="properties[Engraving — {% case i %}{% when 1 %}Front{% when 2 %}Back{% when 3 %}Left{% when 4 %}Right{% endcase %}]"
                         maxlength="{{ section.settings.engraving_max }}"
                         placeholder="{% case i %}{% when 1 %}{{ section.settings.engraving_placeholder | escape }}{% when 2 %}e.g. 82.6403° W{% when 3 %}e.g. EST. 2021{% else %}e.g. a name, a date{% endcase %}"
                         {% if i == 1 and section.settings.engraving_required %}required{% endif %}
                         {% if i > initial_sides %}disabled{% endif %}
                         autocomplete="off">
                </div>
              {%- endfor -%}

              <p class="ep__side-tip" data-four-tip hidden>Tip: coordinates read best split over two sides — latitude on the front, longitude on the back.</p>

              <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
              <input type="hidden" data-prop-place name="properties[_Place Searched]">
              <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
              <div class="field-row">
                <button type="button" class="find-coords" data-locator-open>
                  Find my coordinates →
                </button>
                <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
              </div>
            </div>

          {%- comment -%} ---- DOG TAG (multi-line) ---- {%- endcomment -%}
          {%- elsif preview_type == 'dog-tag' -%}
            <div class="engrave-field" data-dogtag-engraving>
              <p class="option-group buy-step" style="margin-bottom:8px">Your engraving</p>

              <div class="ep ep--dog-tag" aria-hidden="true">
                <svg viewBox="0 0 180 220" class="ep__dog-tag-svg">
                  {%- comment -%} Dog tag shape: rounded rect with notch {%- endcomment -%}
                  <defs>
                    <clipPath id="dt-clip">
                      <path d="M20,0 h140 a20,20 0 0 1 20,20 v180 a20,20 0 0 1 -20,20 h-140 a20,20 0 0 1 -20,-20 v-180 a20,20 0 0 1 20,-20 z"/>
                    </clipPath>
                  </defs>
                  <rect x="0" y="0" width="180" height="220" rx="20" class="ep__metal"/>
                  {%- comment -%} Chain hole {%- endcomment -%}
                  <circle cx="90" cy="18" r="7" fill="none" stroke="#999" stroke-width="1.5"/>
                  {%- comment -%} Engraving lines {%- endcomment -%}
                  <text x="90" y="90" data-dt-line="1" class="ep__engrave-text"
                        data-fit="140" data-fit-chars="14" lengthAdjust="spacingAndGlyphs"
                        data-placeholder="{{ section.settings.engraving_placeholder | escape }}">{{ section.settings.engraving_placeholder }}</text>
                  <text x="90" y="118" data-dt-line="2" class="ep__engrave-text ep__engrave-text--dim"
                        data-fit="140" data-fit-chars="14" lengthAdjust="spacingAndGlyphs"
                        data-placeholder="">—</text>
                  <text x="90" y="146" data-dt-line="3" class="ep__engrave-text ep__engrave-text--dim"
                        data-fit="140" data-fit-chars="14" lengthAdjust="spacingAndGlyphs"
                        data-placeholder="">—</text>
                </svg>
                <p class="ep__hint">Live preview — exactly as we engrave it</p>
              </div>

              <label for="engrave-dt-1">Line 1 — Latitude</label>
              <input type="text" id="engrave-dt-1" data-engrave-input data-dt-input="1"
                     name="properties[Engraving — Line 1]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="27.7676° N"
                     {% if section.settings.engraving_required %}required{% endif %}
                     autocomplete="off">
              <label for="engrave-dt-2" style="margin-top:8px">Line 2 — Longitude</label>
              <input type="text" id="engrave-dt-2" data-dt-input="2"
                     name="properties[Engraving — Line 2]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="82.6403° W"
                     autocomplete="off">
              <label for="engrave-dt-3" style="margin-top:8px">Line 3 — Location name <span style="color:var(--c-ink-soft)">(optional)</span></label>
              <input type="text" id="engrave-dt-3" data-dt-input="3"
                     name="properties[Engraving — Line 3]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="Saint Petersburg, FL"
                     autocomplete="off">

              <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
              <input type="hidden" data-prop-place name="properties[_Place Searched]">
              <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
              <div class="field-row">
                <button type="button" class="find-coords" data-locator-open>
                  Find my coordinates →
                </button>
                <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
              </div>
            </div>

          {%- comment -%} ---- VERTICAL BAR ---- {%- endcomment -%}
          {%- elsif preview_type == 'vertical-bar' -%}
            <div class="engrave-field">
              <label class="option-group buy-step" style="margin-bottom:8px" for="engrave-input">Your engraving</label>
              <div class="ep ep--vertical-bar" aria-hidden="true">
                <svg viewBox="0 0 60 200" class="ep__vbar-svg">
                  {%- comment -%} Chain {%- endcomment -%}
                  <line x1="30" y1="0" x2="30" y2="20" stroke="#bbb" stroke-width="1"/>
                  <circle cx="30" cy="22" r="4" fill="none" stroke="#bbb" stroke-width="1"/>
                  {%- comment -%} Vertical bar pendant {%- endcomment -%}
                  <rect x="16" y="30" width="28" height="160" rx="2" class="ep__metal"/>
                  {%- comment -%} Engraved text runs top→bottom {%- endcomment -%}
                  <text x="30" y="110" data-engrave-preview
                        data-fit="150" data-fit-chars="12" lengthAdjust="spacingAndGlyphs"
                        class="ep__engrave-text ep__engrave-text--vertical"
                        data-placeholder="{{ section.settings.engraving_placeholder | escape }}">{{ section.settings.engraving_placeholder }}</text>
                </svg>
                <p class="ep__hint">Live preview — exactly as we engrave it</p>
              </div>
              <input type="text" id="engrave-input" data-engrave-input
                     name="properties[Engraving]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="{{ section.settings.engraving_placeholder | escape }}"
                     {% if section.settings.engraving_required %}required{% endif %}
                     autocomplete="off">
              <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
              <input type="hidden" data-prop-place name="properties[_Place Searched]">
              <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
              <div class="field-row">
                <button type="button" class="find-coords" data-locator-open>
                  Find my coordinates →
                </button>
                <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
              </div>
            </div>

          {%- comment -%} ---- RING ---- {%- endcomment -%}
          {%- elsif preview_type == 'ring' -%}
            <div class="engrave-field">
              <label class="option-group buy-step" style="margin-bottom:8px" for="engrave-input">Your engraving</label>
              <div class="ep ep--ring" aria-hidden="true">
                <svg viewBox="0 0 220 140" class="ep__ring-svg">
                  {%- comment -%} Ring band — outer ellipse {%- endcomment -%}
                  <ellipse cx="110" cy="70" rx="95" ry="55" fill="none" stroke="#23232a" stroke-width="18" class="ep__ring-band"/>
                  {%- comment -%} Inner highlight {%- endcomment -%}
                  <ellipse cx="110" cy="70" rx="95" ry="55" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="16"/>
                  {%- comment -%} Text along the outer curve — single line {%- endcomment -%}
                  <defs>
                    <path id="ring-text-path" d="M 15,70 A 95,55 0 0 1 205,70" fill="none"/>
                  </defs>
                  <text class="ep__engrave-text ep__engrave-text--curve">
                    <textPath href="#ring-text-path" startOffset="50%" text-anchor="middle"
                              data-engrave-preview
                              data-placeholder="{{ section.settings.engraving_placeholder | escape }}">{{ section.settings.engraving_placeholder }}</textPath>
                  </text>
                </svg>
                <p class="ep__hint">Live preview — single line, exactly as we engrave it</p>
              </div>
              <input type="text" id="engrave-input" data-engrave-input
                     name="properties[Engraving]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="{{ section.settings.engraving_placeholder | escape }}"
                     {% if section.settings.engraving_required %}required{% endif %}
                     autocomplete="off">
              <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
              <input type="hidden" data-prop-place name="properties[_Place Searched]">
              <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
              <div class="field-row">
                <button type="button" class="find-coords" data-locator-open>
                  Find my coordinates →
                </button>
                <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
              </div>
            </div>

          {%- comment -%} ---- BRACELET / CUFF ---- {%- endcomment -%}
          {%- elsif preview_type == 'bracelet' -%}
            <div class="engrave-field">
              <label class="option-group buy-step" style="margin-bottom:8px" for="engrave-input">Your engraving</label>
              <div class="ep ep--bracelet" aria-hidden="true">
                {% render 'set-piece-svg', piece: 'bracelet', placeholder: section.settings.engraving_placeholder, id_prefix: 'solo', mode: 'single' %}
                <p class="ep__hint">Live preview — single line, exactly as we engrave it</p>
              </div>
              <input type="text" id="engrave-input" data-engrave-input
                     name="properties[Engraving]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="{{ section.settings.engraving_placeholder | escape }}"
                     {% if section.settings.engraving_required %}required{% endif %}
                     autocomplete="off">
              <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
              <input type="hidden" data-prop-place name="properties[_Place Searched]">
              <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
              <div class="field-row">
                <button type="button" class="find-coords" data-locator-open>
                  Find my coordinates →
                </button>
                <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
              </div>
            </div>


          {%- comment -%} ---- COORDINATES SET (multi-piece preview) ---- {%- endcomment -%}
          {%- elsif preview_type == 'coordinates-set' -%}
            {%- liquid
              assign _sp = ''
              for tag in product.tags
                assign tag_down = tag | downcase | strip
                if tag_down == 'necklace'
                  assign _sp = _sp | append: 'necklace,'
                elsif tag_down == 'bracelet'
                  assign _sp = _sp | append: 'bracelet,'
                elsif tag_down == 'ring'
                  assign _sp = _sp | append: 'ring,'
                elsif tag_down == 'keychain'
                  assign _sp = _sp | append: 'keychain,'
                endif
              endfor
              assign set_pieces_auto = _sp | split: ','
              assign set_override = section.settings.set_pieces | strip
              if set_override != blank and set_override != 'auto'
                assign set_pieces = set_override | split: ','
              else
                assign set_pieces = set_pieces_auto
              endif

              assign set_style = section.settings.set_necklace_style | default: 'bar'
              assign has_necklace = false
              for piece_raw in set_pieces
                assign piece_probe = piece_raw | strip
                if piece_probe == 'necklace'
                  assign has_necklace = true
                endif
              endfor
            -%}

            {%- if set_style == 'four-sided' and has_necklace -%}
              {%- comment -%}
                DUO SET — e.g. Necklace + Bracelet. The necklace is the
                4-sided bar pendant with its own faces; every other piece
                gets its own realistic scene. One shared coordinates input
                lays the text out per piece exactly as engraved: with 2+
                sides available, latitude goes on the necklace front and
                longitude on the back, while the bracelet carries the full
                pair on one line.
              {%- endcomment -%}
              {%- liquid
                assign ph_full = section.settings.engraving_placeholder
                assign ph_parts = ph_full | split: ','
                assign ph_lat = ph_parts.first | strip
                if ph_parts.size > 1
                  assign ph_rest = ph_full | remove_first: ph_parts.first
                  assign ph_lng = ph_rest | remove_first: ',' | strip
                else
                  assign ph_lat = ph_full
                  assign ph_lng = '82.6403° W'
                endif

                comment
                  Same sides-variant detection as the standalone 4-sided
                  product: constrain the necklace when the set is sold with
                  a sides option; otherwise all 4 sides are available.
                endcomment
                assign sides_option = -1
                for option in product.options_with_values
                  assign joined_values = option.values | join: ' '
                  assign opt_probe = option.name | append: ' ' | append: joined_values | downcase
                  if opt_probe contains 'side'
                    assign sides_option = forloop.index0
                    break
                  endif
                endfor
                assign max_sides = 4
                if sides_option >= 0
                  assign side_val = current_variant.options[sides_option] | downcase
                  if side_val contains '4'
                    assign max_sides = 4
                  elsif side_val contains '3'
                    assign max_sides = 3
                  elsif side_val contains '2'
                    assign max_sides = 2
                  elsif side_val contains '1'
                    assign max_sides = 1
                  endif
                endif
              -%}

              <div class="engrave-field" data-set-duo
                   data-sides-option="{{ sides_option }}" data-max-sides="{{ max_sides }}">
                <p class="option-group buy-step" style="margin-bottom:4px">Your coordinates</p>
                <p class="ep__set-sub">Enter once — we lay them out on each piece exactly as engraved</p>

                <div class="ep ep--duo" aria-hidden="true">
                  {%- comment -%} — the necklace, shown from all engraved sides — {%- endcomment -%}
                  <div class="ep__duo-piece">
                    <span class="ep__duo-title">The necklace</span>
                    <div class="ep__chain">
                      <svg viewBox="0 0 300 42" preserveAspectRatio="xMidYMax meet">
                        <path d="M 6,0 L 150,32 L 294,0" fill="none" class="ep__chain-line"/>
                        <circle cx="150" cy="35" r="4.5" fill="none" class="ep__chain-line"/>
                      </svg>
                    </div>
                    <div class="ep__faces">
                      {%- for i in (1..4) -%}
                        <div class="ep__face" data-face="{{ i }}" data-face-active="{% if i <= max_sides and i <= 2 %}true{% else %}false{% endif %}">
                          <svg viewBox="0 0 44 190" class="ep__face-svg" aria-hidden="true">
                            <rect x="4" y="6" width="36" height="178" rx="3" class="ep__metal"/>
                            <rect x="6.5" y="8.5" width="12" height="173" rx="2.5" class="ep__sheen"/>
                            <rect x="4.7" y="6.7" width="34.6" height="176.6" rx="2.6" class="ep__bevel" fill="none"/>
                            {%- if i <= 2 -%}<circle cx="22" cy="17" r="3" class="ep__hole"/>{%- endif -%}
                            <text x="22" y="{% if i <= 2 %}103{% else %}98{% endif %}" data-duo-face="{{ i }}"
                                  class="ep__engrave-text ep__engrave-text--vertical"
                                  data-fit="150" data-fit-chars="12" lengthAdjust="spacingAndGlyphs"
                                  data-placeholder="{% case i %}{% when 1 %}{{ ph_lat | escape }}{% when 2 %}{{ ph_lng | escape }}{% else %}· · ·{% endcase %}">
                              {%- case i %}{% when 1 %}{{ ph_lat }}{% when 2 %}{{ ph_lng }}{% else %}· · ·{% endcase -%}
                            </text>
                          </svg>
                          <span class="ep__face-label">{% case i %}{% when 1 %}Front{% when 2 %}Back{% when 3 %}Left{% when 4 %}Right{% endcase %}</span>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>

                  {%- comment -%} — every other piece in the set — {%- endcomment -%}
                  {%- for piece_raw in set_pieces -%}
                    {%- assign piece = piece_raw | strip -%}
                    {%- if piece == blank or piece == 'necklace' -%}{%- continue -%}{%- endif -%}
                    <div class="ep__duo-piece">
                      <span class="ep__duo-title">The {{ piece }}</span>
                      {% render 'set-piece-svg', piece: piece, placeholder: ph_full, id_prefix: 'duo' %}
                    </div>
                  {%- endfor -%}

                  <p class="ep__hint">Live preview — each piece exactly as we engrave it</p>
                </div>

                {%- comment -%} shared coordinates input — no-JS fallback submits it as-is {%- endcomment -%}
                <input type="text" id="engrave-input" data-engrave-input data-duo-shared
                       name="properties[Engraving]"
                       maxlength="{{ section.settings.engraving_max }}"
                       placeholder="{{ section.settings.engraving_placeholder | escape }}"
                       {% if section.settings.engraving_required %}required{% endif %}
                       autocomplete="off">
                <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
                <input type="hidden" data-prop-place name="properties[_Place Searched]">
                <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
                <div class="field-row">
                  <button type="button" class="find-coords" data-locator-open>Find my coordinates →</button>
                  <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
                </div>

                <p class="ep__side-tip" data-duo-splitnote hidden>Latitude goes on the necklace front, longitude on the back — automatic.</p>

                {%- comment -%}
                  Per-target properties for the engraving team, managed by
                  JS (disabled while empty so blank lines never reach the
                  order). Names mirror what the customer sees in the preview.
                {%- endcomment -%}
                <input type="hidden" data-duo-prop="1" name="properties[Engraving — Necklace Front]" disabled>
                <input type="hidden" data-duo-prop="2" name="properties[Engraving — Necklace Back]" disabled>
                <input type="hidden" data-duo-prop="3" name="properties[Engraving — Necklace Left]" disabled>
                <input type="hidden" data-duo-prop="4" name="properties[Engraving — Necklace Right]" disabled>
                {%- for piece_raw in set_pieces -%}
                  {%- assign piece = piece_raw | strip -%}
                  {%- if piece == blank or piece == 'necklace' -%}{%- continue -%}{%- endif -%}
                  <input type="hidden" data-duo-piece-prop="{{ piece }}"
                         name="properties[Engraving — {{ piece | capitalize }}]" disabled>
                {%- endfor -%}

                {%- comment -%} optional extra sides on the necklace {%- endcomment -%}
                <div class="ep__duo-extra" data-duo-extra>
                  <p class="ep__duo-extra-label">More sides on the necklace <span>optional — engraving is free</span></p>
                  {%- for i in (2..4) -%}
                    <div class="ep__side-input" data-duo-side-field="{{ i }}"
                         {% if i > max_sides %}style="display:none"{% endif %}>
                      <label for="duo-side-{{ i }}">{% case i %}{% when 2 %}Back{% when 3 %}Left side{% when 4 %}Right side{% endcase %}</label>
                      <input type="text" id="duo-side-{{ i }}"
                             data-duo-side="{{ i }}"
                             maxlength="15"
                             placeholder="{% case i %}{% when 2 %}e.g. {{ ph_lng | escape }}{% when 3 %}e.g. EST. 2021{% else %}e.g. a name, a date{% endcase %}"
                             {% if i > max_sides %}disabled{% endif %}
                             autocomplete="off">
                    </div>
                  {%- endfor -%}
                </div>

                {%- comment -%} per-piece override for everything that isn't the necklace {%- endcomment -%}
                {%- for piece_raw in set_pieces -%}
                  {%- assign piece = piece_raw | strip -%}
                  {%- if piece == blank or piece == 'necklace' -%}{%- continue -%}{%- endif -%}
                  <details class="ep__set-customize">
                    <summary><span class="ep__set-toggle-icon">✦</span> Engrave the {{ piece }} differently</summary>
                    <div class="ep__set-custom-body">
                      <p class="ep__set-custom-note">Leave empty to match the coordinates above.</p>
                      <div class="ep__set-custom-field">
                        <label for="duo-override-{{ piece }}">{{ piece | capitalize }}</label>
                        <input type="text" id="duo-override-{{ piece }}"
                               data-engrave-input data-duo-override="{{ piece }}"
                               maxlength="{{ section.settings.engraving_max }}"
                               placeholder="{{ section.settings.engraving_placeholder | escape }}"
                               autocomplete="off">
                      </div>
                    </div>
                  </details>
                {%- endfor -%}
              </div>

            {%- else -%}
              {%- comment -%} LEGACY SET — one text engraved identically on every piece {%- endcomment -%}
              <div class="engrave-field" data-set-engraving>
                <p class="option-group buy-step" style="margin-bottom:4px">Your coordinates</p>
                <p class="ep__set-sub">Enter once — engraved on every piece in this set</p>

                <div class="ep ep--set" aria-hidden="true">
                  <div class="ep__set-pieces">
                    {%- for piece_raw in set_pieces -%}
                      {%- assign piece = piece_raw | strip -%}
                      {%- if piece == blank -%}{%- continue -%}{%- endif -%}
                      <div class="ep__set-piece" data-set-piece="{{ piece }}">
                        {% render 'set-piece-svg', piece: piece, placeholder: section.settings.engraving_placeholder, id_prefix: 'set' %}
                        <span class="ep__piece-label">{{ piece | capitalize }}</span>
                      </div>
                    {%- endfor -%}
                  </div>
                  <p class="ep__hint">Live preview — all pieces engraved with your coordinates</p>
                </div>

                <div data-set-unified>
                  <input type="text" id="engrave-input" data-engrave-input data-set-sync
                         name="properties[Engraving]"
                         maxlength="{{ section.settings.engraving_max }}"
                         placeholder="{{ section.settings.engraving_placeholder | escape }}"
                         {% if section.settings.engraving_required %}required{% endif %}
                         autocomplete="off">
                  <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
                  <input type="hidden" data-prop-place name="properties[_Place Searched]">
                  <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
                  <div class="field-row">
                    <button type="button" class="find-coords" data-locator-open>Find my coordinates →</button>
                    <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
                  </div>
                </div>

                {%- for piece_raw in set_pieces -%}
                  {%- assign piece = piece_raw | strip -%}
                  {%- if piece == blank -%}{%- continue -%}{%- endif -%}
                  <input type="hidden" data-set-piece-prop="{{ piece }}"
                         name="properties[Engraving — {{ piece | capitalize }}]">
                {%- endfor -%}

                <details class="ep__set-customize" data-set-customize>
                  <summary><span class="ep__set-toggle-icon">✦</span> Customize each piece separately</summary>
                  <div class="ep__set-custom-body">
                    <p class="ep__set-custom-note">Enter different coordinates for each piece. Use "Find my coordinates" for each.</p>
                    {%- for piece_raw in set_pieces -%}
                      {%- assign piece = piece_raw | strip -%}
                      {%- if piece == blank -%}{%- continue -%}{%- endif -%}
                      <div class="ep__set-custom-field">
                        <label for="set-engrave-{{ piece }}">{{ piece | capitalize }}</label>
                        <input type="text" id="set-engrave-{{ piece }}"
                               data-engrave-input data-set-piece-input="{{ piece }}"
                               maxlength="{{ section.settings.engraving_max }}"
                               placeholder="{{ section.settings.engraving_placeholder | escape }}"
                               autocomplete="off">
                      </div>
                    {%- endfor -%}
                  </div>
                </details>
              </div>
            {%- endif -%}

          {%- comment -%} ---- HORIZONTAL BAR (default) ---- {%- endcomment -%}
          {%- else -%}
            <div class="engrave-field">
              <label class="option-group buy-step" style="margin-bottom:8px" for="engrave-input">Your engraving</label>
              <div class="ep ep--horizontal-bar" aria-hidden="true">
                <svg viewBox="0 0 280 70" class="ep__hbar-svg">
                  {%- comment -%} Horizontal bar pendant {%- endcomment -%}
                  <rect x="0" y="10" width="280" height="50" rx="3" class="ep__metal"/>
                  {%- comment -%} Engraved text — single line left to right {%- endcomment -%}
                  <text x="140" y="42" data-engrave-preview
                        data-fit="250" data-fit-chars="22" lengthAdjust="spacingAndGlyphs"
                        class="ep__engrave-text"
                        data-placeholder="{{ section.settings.engraving_placeholder | escape }}">{{ section.settings.engraving_placeholder }}</text>
                </svg>
                <p class="ep__hint">Live preview — exactly as we engrave it</p>
              </div>
              <input type="text" id="engrave-input" data-engrave-input
                     name="properties[Engraving]"
                     maxlength="{{ section.settings.engraving_max }}"
                     placeholder="{{ section.settings.engraving_placeholder | escape }}"
                     {% if section.settings.engraving_required %}required{% endif %}
                     autocomplete="off">
              <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
              <input type="hidden" data-prop-place name="properties[_Place Searched]">
              <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
              <div class="field-row">
                <button type="button" class="find-coords" data-locator-open>
                  Find my coordinates →
                </button>
                <span data-engrave-count>0 / {{ section.settings.engraving_max }}</span>
              </div>
            </div>
          {%- endif -%}

        {%- endif -%}

        {%- comment -%}
          Gift packaging add-on. Progressive enhancement: rendered hidden,
          revealed by the cart-drawer JS that also performs the extra add —
          so it never appears without the code that makes it work.
        {%- endcomment -%}
        {%- liquid
          assign gift_wrap = settings.gift_wrap_product
        -%}
        {%- if gift_wrap != blank and gift_wrap.available and product.id != gift_wrap.id -%}
          <label class="gift-wrap-addon" data-gift-wrap-addon hidden>
            <input type="checkbox" data-gift-wrap value="{{ gift_wrap.selected_or_first_available_variant.id }}">
            <span class="gift-wrap-addon__text">
              <strong>Make it gift-ready</strong> (+{{ gift_wrap.price | money }})
              <em>{{ gift_wrap.title }} — wrapped and ready to hand over</em>
            </span>
          </label>
        {%- endif -%}

        <button type="submit" class="btn btn--full" data-atc
                data-label-add="{{ section.settings.atc_label | escape }}"
                data-label-sold-out="Back soon — notify me">
          <span data-atc-label>{{ section.settings.atc_label }}</span>
        </button>

        <ul class="guarantees">
          {%- if settings.guarantee_1 != blank -%}<li>{{ settings.guarantee_1 }}</li>{%- endif -%}
          {%- if settings.guarantee_2 != blank -%}<li>{{ settings.guarantee_2 }}</li>{%- endif -%}
          {%- if settings.guarantee_3 != blank -%}<li>{{ settings.guarantee_3 }}</li>{%- endif -%}
        </ul>
      {%- endform -%}

      {%- comment -%} ---------- ACCORDIONS ---------- {%- endcomment -%}
      <div class="pdp__accordions">
        <details open>
          <summary>Description</summary>
          <div class="accordion-body rte">{{ product.description }}</div>
        </details>
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details {{ block.shopify_attributes }}>
              <summary>{{ block.settings.title }}</summary>
              <div class="accordion-body rte">{{ block.settings.content }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
        <details>
          <summary>Shipping &amp; returns</summary>
          <div class="accordion-body">
            {%- if section.settings.show_engraving -%}
              <p>{{ settings.shipping_promise }}. Each piece is engraved to order and ships within {{ settings.production_days }} business days. 30-day happiness guarantee — if it's not right, we'll remake it or refund you.</p>
            {%- else -%}
              <p>{{ settings.shipping_promise }}. Ships within {{ settings.production_days }} business days. 30-day happiness guarantee — if it's not right, we'll replace it or refund you.</p>
            {%- endif -%}
          </div>
        </details>
      </div>

      <div id="reviews">
        {%- if section.settings.review_style == 'app' -%}
          {%- comment -%} Judge.me app embed fills this with the full review list {%- endcomment -%}
          <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}" data-product-title="{{ product.title | escape }}"></div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <script type="application/json" data-product-json>{{ product | json }}</script>
</section>

{%- comment -%}
  Recently viewed — localStorage only, populated client-side from
  /products/{handle}.js. Stays hidden until there is something to show.
{%- endcomment -%}
{%- if section.settings.show_recently_viewed -%}
<section class="section" data-recently-viewed data-current-handle="{{ product.handle }}" hidden>
  <div class="page-width">
    <div class="section-head">
      <div>
        <p class="coord-eyebrow">Retrace your steps</p>
        <h2 style="margin:0">Recently viewed</h2>
      </div>
    </div>
    <div class="product-grid" data-rv-grid></div>
  </div>
</section>
{%- endif -%}

{%- comment -%} ---------- ON-PAGE COORDINATES LOCATOR ---------- {%- endcomment -%}
<dialog class="locator" data-locator>
  <div class="locator__head">
    <div>
      <p class="coord-eyebrow" style="margin-bottom:4px">Pin your place</p>
      <h3 style="margin:0">Find your coordinates</h3>
    </div>
    <button type="button" class="locator__close" data-locator-close aria-label="Close">✕</button>
  </div>

  <div class="locator__search">
    <input type="search" data-locator-search placeholder="Search a place, address, or city…" aria-label="Search for a place">
    <button type="button" class="btn" data-locator-go>Search</button>
  </div>
  <p class="locator__hint">Search, then drag the map or tap to drop the pin on your exact spot.</p>

  <div class="locator__map" data-locator-map>
    <p class="locator__loading">Loading map…</p>
  </div>

  <div class="locator__result">
    <span class="locator__coords" data-locator-coords>—</span>
    <button type="button" class="btn" data-locator-use disabled>Use these coordinates</button>
  </div>
</dialog>

{%- comment -%} ---------- STICKY MOBILE ADD TO CART ---------- {%- endcomment -%}
<div class="sticky-atc" data-sticky-atc>
  <span class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</span>
  <button type="button" class="btn" data-sticky-submit data-atc
          data-label-add="{{ section.settings.atc_label | escape }}"
          data-label-sold-out="Back soon">
    <span data-atc-label>{{ section.settings.atc_label }}</span>
  </button>
</div>

{%- comment -%} ── Product JSON-LD Schema (rich snippets) ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  {%- if product.featured_image -%}
  "image": [
    "{{ product.featured_image | image_url: width: 1200 }}"
    {%- for image in product.images offset: 1 limit: 4 -%}
    ,"{{ image | image_url: width: 1200 }}"
    {%- endfor -%}
  ],
  {%- endif -%}
  {%- if product.selected_or_first_available_variant.sku != blank -%}
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  {%- endif -%}
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "lowPrice": {{ product.price_min | money_without_currency | remove: ',' | json }},
    "highPrice": {{ product.price_max | money_without_currency | remove: ',' | json }},
    "offerCount": {{ product.variants.size }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "US"
      },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": {
          "@type": "QuantitativeValue",
          "minValue": {{ settings.production_days | default: 3 }},
          "maxValue": {{ settings.production_days | default: 3 | plus: 2 }},
          "unitCode": "DAY"
        },
        "transitTime": {
          "@type": "QuantitativeValue",
          "minValue": {{ settings.transit_days | default: 3 }},
          "maxValue": {{ settings.transit_days | default: 5 | plus: 3 }},
          "unitCode": "DAY"
        }
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 30,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  }
}
</script>

{% schema %}
{
  "name": "Product page",
  "settings": [
    {
      "type": "select",
      "id": "preview_type",
      "label": "Engraving preview shape",
      "options": [
        { "value": "horizontal-bar", "label": "Horizontal bar (flat bar pendant)" },
        { "value": "vertical-bar", "label": "Vertical bar (tall pendant, text top→bottom)" },
        { "value": "ring", "label": "Ring band (text along curve)" },
        { "value": "bracelet", "label": "Bracelet / cuff (text along curve)" },
        { "value": "four-sided", "label": "4-sided bar (multi-side inputs)" },
        { "value": "dog-tag", "label": "Dog tag (2–3 lines)" },
        { "value": "coordinates-set", "label": "Coordinates set (multi-piece preview)" }
      ],
      "default": "horizontal-bar"
    },
    {
      "type": "select",
      "id": "review_style",
      "label": "Review summary under title",
      "options": [
        { "value": "app", "label": "Judge.me badge (real star rating)" },
        { "value": "link", "label": "Plain link to reviews page" },
        { "value": "none", "label": "Hidden" }
      ],
      "default": "app",
      "info": "'Judge.me badge' requires the Judge.me app embed to be enabled — it shows the product's real rating and review count."
    },
    { "type": "checkbox", "id": "show_engraving", "label": "Show engraving field + live preview", "default": true },
    { "type": "checkbox", "id": "engraving_required", "label": "Require engraving before add to cart", "default": true },
    { "type": "text", "id": "engraving_placeholder", "label": "Engraving placeholder", "default": "27.7676° N, 82.6403° W" },
    { "type": "range", "id": "engraving_max", "label": "Max engraving characters", "min": 10, "max": 60, "step": 5, "default": 30 },
    { "type": "text", "id": "atc_label", "label": "Add to cart label", "default": "Add to cart — free engraving" },
    { "type": "checkbox", "id": "show_recently_viewed", "label": "Show 'Recently viewed' strip", "default": true },
    { "type": "text", "id": "set_pieces", "label": "Set pieces (auto or comma-separated: bracelet,necklace,ring,keychain)", "default": "auto" },
    {
      "type": "select",
      "id": "set_necklace_style",
      "label": "Set necklace style",
      "options": [
        { "value": "bar", "label": "Simple bar (same text on every piece)" },
        { "value": "four-sided", "label": "4-sided pendant (per-side inputs + per-piece previews)" }
      ],
      "default": "bar",
      "info": "For sets whose necklace is the 4-sided bar (e.g. Necklace + Bracelet Set): shows the pendant from every side, splits coordinates across front/back automatically, and gives each piece its own preview."
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Product details" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Material, sizing, and care details.</p>" }
      ]
    }
  ]
}
{% endschema %}
