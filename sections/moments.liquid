<section class="section moments">
  <div class="page-width">
    <p class="coord-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <div class="moments__grid">
      {%- for block in section.blocks -%}
        {%- assign title_handle = block.settings.title | handleize -%}
        {%- if title_handle contains 'proposal' -%}
          {%- assign img_slug = 'proposal' -%}
        {%- elsif title_handle contains 'birthplace' or title_handle contains 'birth' -%}
          {%- assign img_slug = 'birthplace' -%}
        {%- elsif title_handle contains 'hometown' or title_handle contains 'home' -%}
          {%- assign img_slug = 'hometown' -%}
        {%- elsif title_handle contains 'meet' or title_handle contains 'meeting' or title_handle contains 'met' -%}
          {%- assign img_slug = 'meeting' -%}
        {%- elsif title_handle contains 'memory' or title_handle contains 'resting' -%}
          {%- assign img_slug = 'memory' -%}
        {%- elsif title_handle contains 'dream' or title_handle contains 'someday' -%}
          {%- assign img_slug = 'dream' -%}
        {%- else -%}
          {%- capture img_slug -%}moment-{{ forloop.index }}{%- endcapture -%}
        {%- endif -%}
        <a class="moments__card" href="{{ block.settings.link | default: '/collections/coordinates-collection' }}" {{ block.shopify_attributes }}>
          <div class="moments__image-wrapper">
            {%- if block.settings.image != blank -%}
              <img class="moments__image"
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="400"
                height="267">
            {%- else -%}
              {%- capture fallback_name -%}moment-{{ img_slug }}.png{%- endcapture -%}
              <img class="moments__image"
                src="{{ fallback_name | asset_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="400"
                height="267">
            {%- endif -%}
          </div>
          <span class="moments__coords">{{ block.settings.coords }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Moments",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "moment",
      "name": "Moment",
      "settings": [
        { "type": "text", "id": "coords", "label": "Coordinates label", "default": "LAT 0.0000 / LNG 0.0000" },
        { "type": "text", "id": "title", "label": "Title", "default": "The proposal" },
        { "type": "text", "id": "text", "label": "Text", "default": "The exact spot you knelt down." },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Moments",
      "settings": {},
      "blocks": [
        { "type": "moment", "settings": { "coords": "THE QUESTION", "title": "The proposal", "text": "The exact spot you knelt down. Engraved where only you two will know what it means." } },
        { "type": "moment", "settings": { "coords": "DAY ONE", "title": "Their birthplace", "text": "The hospital, the town, the street. A first chapter they can carry." } },
        { "type": "moment", "settings": { "coords": "STILL HOME", "title": "The hometown", "text": "For the one who moved away but never really left." } },
        { "type": "moment", "settings": { "coords": "FIRST MEETING", "title": "Where you met", "text": "A coffee shop. A concert. Gate B12. The odds were impossible and it happened anyway." } },
        { "type": "moment", "settings": { "coords": "IN MEMORY", "title": "A resting place", "text": "Quiet, personal, always close. A way to keep someone with you." } },
        { "type": "moment", "settings": { "coords": "SOMEDAY", "title": "The dream", "text": "The place you haven't been yet. Wear it until you get there." } }
      ]
    }
  ]
}
{% endschema %}
