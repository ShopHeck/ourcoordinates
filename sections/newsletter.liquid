<section class="section newsletter">
  <div class="page-width page-narrow">
    <p class="coord-eyebrow" style="justify-content:center">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    {%- form 'customer' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Your email" required aria-label="Email">
      <button type="submit" class="btn">Subscribe</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Members only" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get first access to new drops" },
    { "type": "text", "id": "text", "label": "Text", "default": "One email a month. Early access, gift-date reminders, nothing else." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
