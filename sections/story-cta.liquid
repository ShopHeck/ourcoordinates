{%- comment -%}
  STORY CTA — sentimental bridge for shoppers who don't know the
  coordinates yet. Points at the gift finder / story builder so the
  emotional visitors become personalizers instead of bouncing.
{%- endcomment -%}

<section class="story-cta">
  <div class="hero__topo" aria-hidden="true">
    <svg viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" fill="none" stroke="#fff" stroke-width="1">
      <path d="M-50 480 C 150 420, 280 520, 460 460 S 760 380, 940 440 S 1180 520, 1280 470"/>
      <path d="M-50 400 C 170 340, 310 440, 490 380 S 780 300, 960 360 S 1200 440, 1280 390"/>
      <path d="M-50 320 C 200 270, 340 360, 520 305 S 790 225, 970 285 S 1210 360, 1280 310"/>
      <path d="M-50 240 C 230 200, 370 280, 550 235 S 800 165, 980 215 S 1220 280, 1280 232"/>
      <path d="M-50 160 C 260 140, 400 200, 580 165 S 820 102, 1000 142 S 1240 200, 1280 155"/>
    </svg>
  </div>

  <div class="page-width story-cta__inner">
    <div class="story-cta__copy">
      <p class="coord-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p class="story-cta__text">{{ section.settings.text }}</p>
      <div class="hero__cta">
        {%- liquid
          if section.settings.button_link != blank
            assign story_link = section.settings.button_link
          else
            assign story_link = routes.all_products_collection_url
          endif
        -%}
        {%- if section.settings.button_label != blank -%}
          <a class="btn" href="{{ story_link }}">{{ section.settings.button_label }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank and section.settings.button_link_2 != blank -%}
          <a class="btn btn--hero-ghost" href="{{ section.settings.button_link_2 }}">{{ section.settings.button_label_2 }}</a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="story-cta__stats">
        {%- for block in section.blocks -%}
          <div class="story-cta__stat" {{ block.shopify_attributes }}>
            <span class="story-cta__num">{{ block.settings.number }}</span>
            <span class="story-cta__label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Story CTA",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Don't know the coordinates?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Start with the story. We'll find the spot." },
    {
      "type": "textarea", "id": "text", "label": "Text",
      "default": "Tell us about the person and the moment — a first date, a hometown, the place you said yes. Our 60-second gift finder turns the story into the right piece, exact coordinates and all."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Find the perfect piece" },
    { "type": "url", "id": "button_link", "label": "Button link", "info": "Point this at your gift finder or builder page. Falls back to all products if empty." },
    { "type": "text", "id": "button_label_2", "label": "Secondary button label", "default": "See how it works" },
    { "type": "url", "id": "button_link_2", "label": "Secondary button link" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "4.9★" },
        { "type": "text", "id": "label", "label": "Label", "default": "average review" }
      ]
    }
  ],
  "presets": [{ "name": "Story CTA" }]
}
{% endschema %}
