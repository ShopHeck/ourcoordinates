{%- comment -%}
  Extracted from sections/main-product.liquid so the section stays under
  Shopify's per-file size limit for sections — files over ~50 KB are
  silently skipped by the GitHub theme sync (see docs/deployment.md).
  Accepts:
    engraving_placeholder / engraving_max / engraving_required —
      the section's engraving settings, passed through verbatim.
    set_pieces_setting / set_necklace_style_setting — the section's set
      configuration. current_variant — the selected variant.
{%- endcomment -%}
            {%- liquid
              assign _sp = ''
              for tag in product.tags
                assign tag_down = tag | downcase | strip
                if tag_down == 'necklace'
                  assign _sp = _sp | append: 'necklace,'
                elsif tag_down == 'bracelet'
                  assign _sp = _sp | append: 'bracelet,'
                elsif tag_down == 'ring'
                  assign _sp = _sp | append: 'ring,'
                elsif tag_down == 'keychain'
                  assign _sp = _sp | append: 'keychain,'
                endif
              endfor
              assign set_pieces_auto = _sp | split: ','
              assign set_override = set_pieces_setting | strip
              if set_override != blank and set_override != 'auto'
                assign set_pieces = set_override | split: ','
              else
                assign set_pieces = set_pieces_auto
              endif

              assign set_style = set_necklace_style_setting | default: 'bar'
              assign has_necklace = false
              for piece_raw in set_pieces
                assign piece_probe = piece_raw | strip
                if piece_probe == 'necklace'
                  assign has_necklace = true
                endif
              endfor
            -%}

            {%- if set_style == 'four-sided' and has_necklace -%}
              {%- comment -%}
                DUO SET — e.g. Necklace + Bracelet. The necklace is the
                4-sided bar pendant with its own faces; every other piece
                gets its own realistic scene. One shared coordinates input
                lays the text out per piece exactly as engraved: with 2+
                sides available, latitude goes on the necklace front and
                longitude on the back, while the bracelet carries the full
                pair on one line.
              {%- endcomment -%}
              {%- liquid
                assign ph_full = engraving_placeholder
                assign ph_parts = ph_full | split: ','
                assign ph_lat = ph_parts.first | strip
                if ph_parts.size > 1
                  assign ph_rest = ph_full | remove_first: ph_parts.first
                  assign ph_lng = ph_rest | remove_first: ',' | strip
                else
                  assign ph_lat = ph_full
                  assign ph_lng = '82.6403° W'
                endif

                comment
                  Same sides-variant detection as the standalone 4-sided
                  product: constrain the necklace when the set is sold with
                  a sides option; otherwise all 4 sides are available.
                endcomment
                assign sides_option = -1
                for option in product.options_with_values
                  assign joined_values = option.values | join: ' '
                  assign opt_probe = option.name | append: ' ' | append: joined_values | downcase
                  if opt_probe contains 'side'
                    assign sides_option = forloop.index0
                    break
                  endif
                endfor
                assign max_sides = 4
                if sides_option >= 0
                  assign side_val = current_variant.options[sides_option] | downcase
                  if side_val contains '4'
                    assign max_sides = 4
                  elsif side_val contains '3'
                    assign max_sides = 3
                  elsif side_val contains '2'
                    assign max_sides = 2
                  elsif side_val contains '1'
                    assign max_sides = 1
                  endif
                endif
              -%}

              <div class="engrave-field" data-set-duo
                   data-sides-option="{{ sides_option }}" data-max-sides="{{ max_sides }}">
                <p class="option-group buy-step" style="margin-bottom:4px">Your coordinates</p>
                <p class="ep__set-sub">Enter once — we lay them out on each piece exactly as engraved</p>

                <div class="ep ep--duo" aria-hidden="true">
                  {%- comment -%} — the necklace, shown from all engraved sides — {%- endcomment -%}
                  <div class="ep__duo-piece">
                    <span class="ep__duo-title">The necklace</span>
                    <div class="ep__chain">
                      <svg viewBox="0 0 300 42" preserveAspectRatio="xMidYMax meet">
                        <path d="M 6,0 L 150,32 L 294,0" fill="none" class="ep__chain-line"/>
                        <circle cx="150" cy="35" r="4.5" fill="none" class="ep__chain-line"/>
                      </svg>
                    </div>
                    <div class="ep__faces">
                      {%- for i in (1..4) -%}
                        <div class="ep__face" data-face="{{ i }}" data-face-active="{% if i <= max_sides and i <= 2 %}true{% else %}false{% endif %}">
                          <svg viewBox="0 0 44 190" class="ep__face-svg" aria-hidden="true">
                            <rect x="4" y="6" width="36" height="178" rx="3" class="ep__metal"/>
                            <rect x="6.5" y="8.5" width="12" height="173" rx="2.5" class="ep__sheen"/>
                            <rect x="4.7" y="6.7" width="34.6" height="176.6" rx="2.6" class="ep__bevel" fill="none"/>
                            {%- if i <= 2 -%}<circle cx="22" cy="17" r="3" class="ep__hole"/>{%- endif -%}
                            <text x="22" y="{% if i <= 2 %}103{% else %}98{% endif %}" data-duo-face="{{ i }}"
                                  class="ep__engrave-text ep__engrave-text--vertical"
                                  data-fit="150" data-fit-chars="12" lengthAdjust="spacingAndGlyphs"
                                  data-placeholder="{% case i %}{% when 1 %}{{ ph_lat | escape }}{% when 2 %}{{ ph_lng | escape }}{% else %}· · ·{% endcase %}">
                              {%- case i %}{% when 1 %}{{ ph_lat }}{% when 2 %}{{ ph_lng }}{% else %}· · ·{% endcase -%}
                            </text>
                          </svg>
                          <span class="ep__face-label">{% case i %}{% when 1 %}Front{% when 2 %}Back{% when 3 %}Left{% when 4 %}Right{% endcase %}</span>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>

                  {%- comment -%} — every other piece in the set — {%- endcomment -%}
                  {%- for piece_raw in set_pieces -%}
                    {%- assign piece = piece_raw | strip -%}
                    {%- if piece == blank or piece == 'necklace' -%}{%- continue -%}{%- endif -%}
                    <div class="ep__duo-piece">
                      <span class="ep__duo-title">The {{ piece }}</span>
                      {% render 'set-piece-svg', piece: piece, placeholder: ph_full, id_prefix: 'duo' %}
                    </div>
                  {%- endfor -%}

                  <p class="ep__hint">Live preview — each piece exactly as we engrave it</p>
                </div>

                {%- comment -%} shared coordinates input — no-JS fallback submits it as-is {%- endcomment -%}
                <input type="text" id="engrave-input" data-engrave-input data-duo-shared
                       name="properties[Engraving]"
                       maxlength="{{ engraving_max }}"
                       placeholder="{{ engraving_placeholder | escape }}"
                       {% if engraving_required %}required{% endif %}
                       autocomplete="off">
                <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
                <input type="hidden" data-prop-place name="properties[_Place Searched]">
                <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
                <div class="field-row">
                  <button type="button" class="find-coords" data-locator-open>Find my coordinates →</button>
                  <span data-engrave-count>0 / {{ engraving_max }}</span>
                </div>

                <p class="ep__side-tip" data-duo-splitnote hidden>Latitude goes on the necklace front, longitude on the back — automatic.</p>

                {%- comment -%}
                  Per-target properties for the engraving team, managed by
                  JS (disabled while empty so blank lines never reach the
                  order). Names mirror what the customer sees in the preview.
                {%- endcomment -%}
                <input type="hidden" data-duo-prop="1" name="properties[Engraving — Necklace Front]" disabled>
                <input type="hidden" data-duo-prop="2" name="properties[Engraving — Necklace Back]" disabled>
                <input type="hidden" data-duo-prop="3" name="properties[Engraving — Necklace Left]" disabled>
                <input type="hidden" data-duo-prop="4" name="properties[Engraving — Necklace Right]" disabled>
                {%- for piece_raw in set_pieces -%}
                  {%- assign piece = piece_raw | strip -%}
                  {%- if piece == blank or piece == 'necklace' -%}{%- continue -%}{%- endif -%}
                  <input type="hidden" data-duo-piece-prop="{{ piece }}"
                         name="properties[Engraving — {{ piece | capitalize }}]" disabled>
                {%- endfor -%}

                {%- comment -%} optional extra sides on the necklace {%- endcomment -%}
                <div class="ep__duo-extra" data-duo-extra>
                  <p class="ep__duo-extra-label">More sides on the necklace <span>optional — engraving is free</span></p>
                  {%- for i in (2..4) -%}
                    <div class="ep__side-input" data-duo-side-field="{{ i }}"
                         {% if i > max_sides %}style="display:none"{% endif %}>
                      <label for="duo-side-{{ i }}">{% case i %}{% when 2 %}Back{% when 3 %}Left side{% when 4 %}Right side{% endcase %}</label>
                      <input type="text" id="duo-side-{{ i }}"
                             data-duo-side="{{ i }}"
                             maxlength="15"
                             placeholder="{% case i %}{% when 2 %}e.g. {{ ph_lng | escape }}{% when 3 %}e.g. EST. 2021{% else %}e.g. a name, a date{% endcase %}"
                             {% if i > max_sides %}disabled{% endif %}
                             autocomplete="off">
                    </div>
                  {%- endfor -%}
                </div>

                {%- comment -%} per-piece override for everything that isn't the necklace {%- endcomment -%}
                {%- for piece_raw in set_pieces -%}
                  {%- assign piece = piece_raw | strip -%}
                  {%- if piece == blank or piece == 'necklace' -%}{%- continue -%}{%- endif -%}
                  <details class="ep__set-customize">
                    <summary><span class="ep__set-toggle-icon">✦</span> Engrave the {{ piece }} differently</summary>
                    <div class="ep__set-custom-body">
                      <p class="ep__set-custom-note">Leave empty to match the coordinates above.</p>
                      <div class="ep__set-custom-field">
                        <label for="duo-override-{{ piece }}">{{ piece | capitalize }}</label>
                        <input type="text" id="duo-override-{{ piece }}"
                               data-engrave-input data-duo-override="{{ piece }}"
                               maxlength="{{ engraving_max }}"
                               placeholder="{{ engraving_placeholder | escape }}"
                               autocomplete="off">
                      </div>
                    </div>
                  </details>
                {%- endfor -%}
              </div>

            {%- else -%}
              {%- comment -%} LEGACY SET — one text engraved identically on every piece {%- endcomment -%}
              <div class="engrave-field" data-set-engraving>
                <p class="option-group buy-step" style="margin-bottom:4px">Your coordinates</p>
                <p class="ep__set-sub">Enter once — engraved on every piece in this set</p>

                <div class="ep ep--set" aria-hidden="true">
                  <div class="ep__set-pieces">
                    {%- for piece_raw in set_pieces -%}
                      {%- assign piece = piece_raw | strip -%}
                      {%- if piece == blank -%}{%- continue -%}{%- endif -%}
                      <div class="ep__set-piece" data-set-piece="{{ piece }}">
                        {% render 'set-piece-svg', piece: piece, placeholder: engraving_placeholder, id_prefix: 'set' %}
                        <span class="ep__piece-label">{{ piece | capitalize }}</span>
                      </div>
                    {%- endfor -%}
                  </div>
                  <p class="ep__hint">Live preview — all pieces engraved with your coordinates</p>
                </div>

                <div data-set-unified>
                  <input type="text" id="engrave-input" data-engrave-input data-set-sync
                         name="properties[Engraving]"
                         maxlength="{{ engraving_max }}"
                         placeholder="{{ engraving_placeholder | escape }}"
                         {% if engraving_required %}required{% endif %}
                         autocomplete="off">
                  <input type="hidden" data-prop-latlng name="properties[_Exact Decimal Coordinates]">
                  <input type="hidden" data-prop-place name="properties[_Place Searched]">
                  <input type="hidden" data-prop-maplink name="properties[_Verify on Map]">
                  <div class="field-row">
                    <button type="button" class="find-coords" data-locator-open>Find my coordinates →</button>
                    <span data-engrave-count>0 / {{ engraving_max }}</span>
                  </div>
                </div>

                {%- for piece_raw in set_pieces -%}
                  {%- assign piece = piece_raw | strip -%}
                  {%- if piece == blank -%}{%- continue -%}{%- endif -%}
                  <input type="hidden" data-set-piece-prop="{{ piece }}"
                         name="properties[Engraving — {{ piece | capitalize }}]">
                {%- endfor -%}

                <details class="ep__set-customize" data-set-customize>
                  <summary><span class="ep__set-toggle-icon">✦</span> Customize each piece separately</summary>
                  <div class="ep__set-custom-body">
                    <p class="ep__set-custom-note">Enter different coordinates for each piece. Use "Find my coordinates" for each.</p>
                    {%- for piece_raw in set_pieces -%}
                      {%- assign piece = piece_raw | strip -%}
                      {%- if piece == blank -%}{%- continue -%}{%- endif -%}
                      <div class="ep__set-custom-field">
                        <label for="set-engrave-{{ piece }}">{{ piece | capitalize }}</label>
                        <input type="text" id="set-engrave-{{ piece }}"
                               data-engrave-input data-set-piece-input="{{ piece }}"
                               maxlength="{{ engraving_max }}"
                               placeholder="{{ engraving_placeholder | escape }}"
                               autocomplete="off">
                      </div>
                    {%- endfor -%}
                  </div>
                </details>
              </div>
            {%- endif -%}
{% comment %} sync nudge — force re-upload after partial sync on 2026-07-12 {% endcomment %}
