{%- comment -%}
  Renders one engravable piece as a realistic SVG.
  Params:
    piece        — 'bracelet' | 'necklace' | 'ring' | 'keychain'
    placeholder  — sample engraving shown until the shopper types
    id_prefix    — unique per render to keep SVG ids from colliding
    mode         — 'set' (default) emits data-set-preview="{piece}" on the
                   text node; 'single' emits data-engrave-preview for the
                   standalone single-input renderer.
  All metal surfaces use .ep__metal / .ep__ring-band so they recolor live
  with the chosen metal variant.
{%- endcomment -%}
{%- liquid
  assign _mode = mode | default: 'set'
-%}
{%- case piece -%}

  {%- when 'bracelet' -%}
    {%- comment -%}
      Open cuff seen in three-quarter view: the band sweeps around the
      bottom, the gap and ball terminals face up — the classic cuff
      silhouette. The engraving sits in a recessed channel along the
      front of the band, so the text always reads light-on-dark no
      matter which metal the band recolors to.
    {%- endcomment -%}
    <svg viewBox="0 0 340 200" class="ep__set-svg ep__set-svg--bracelet" aria-hidden="true">
      <defs>
        <path id="{{ id_prefix }}-cuff-text" d="M 73.4,137.3 A 118,68.5 0 0 0 266.6,137.3" fill="none"/>
      </defs>
      {%- comment -%} The band: outer sweep, back along the inner edge {%- endcomment -%}
      <path d="M 94.3,34.1 A 132,78 0 1 0 245.7,34.1 L 229.7,55.4 A 104,52 0 1 1 110.3,55.4 Z" class="ep__metal"/>
      {%- comment -%} Brushed sheen down the left arm, rim light, inner shadow {%- endcomment -%}
      <path d="M 92.9,47.4 A 120,66 0 0 0 54.1,115.1" class="ep__cuff-sheen" stroke-width="9"/>
      <path d="M 94.3,34.1 A 132,78 0 1 0 245.7,34.1" class="ep__cuff-rim" stroke-width="1"/>
      <path d="M 229.7,55.4 A 104,52 0 1 1 110.3,55.4" class="ep__cuff-inner-shadow" stroke-width="1.5"/>
      {%- comment -%} Ball terminals at the opening {%- endcomment -%}
      <circle cx="102.3" cy="44.7" r="13.2" class="ep__metal"/>
      <circle cx="102.3" cy="44.7" r="13.2" fill="none" class="ep__cuff-rim" stroke-width="0.8"/>
      <circle cx="99" cy="41.4" r="2.2" fill="rgba(255,255,255,0.35)"/>
      <circle cx="237.7" cy="44.7" r="13.2" class="ep__metal"/>
      <circle cx="237.7" cy="44.7" r="13.2" fill="none" class="ep__cuff-rim" stroke-width="0.8"/>
      <circle cx="234.4" cy="41.4" r="2.2" fill="rgba(255,255,255,0.35)"/>
      {%- comment -%} Recessed engraving channel along the front {%- endcomment -%}
      <path d="M 73.4,135.3 A 118,65 0 0 0 266.6,135.3" class="ep__cuff-channel" stroke-width="17"/>
      <path d="M 73.4,135.3 A 118,65 0 0 0 266.6,135.3" class="ep__cuff-channel ep__cuff-channel--core" stroke-width="13"/>
      <text class="ep__engrave-text ep__engrave-text--curve ep__cuff-engrave" text-anchor="middle">
        <textPath href="#{{ id_prefix }}-cuff-text" startOffset="50%"
                  {% if _mode == 'single' %}data-engrave-preview{% else %}data-set-preview="bracelet"{% endif %}
                  data-fit="170" data-fit-chars="18" lengthAdjust="spacingAndGlyphs"
                  data-placeholder="{{ placeholder | escape }}">{{ placeholder }}</textPath>
      </text>
    </svg>

  {%- when 'necklace' -%}
    <svg viewBox="0 0 60 200" class="ep__set-svg ep__set-svg--necklace" aria-hidden="true">
      <line x1="30" y1="0" x2="30" y2="20" class="ep__chain-line" stroke-width="1"/>
      <circle cx="30" cy="22" r="4" fill="none" class="ep__chain-line" stroke-width="1"/>
      <rect x="16" y="30" width="28" height="160" rx="2" class="ep__metal"/>
      <rect x="18" y="32" width="9" height="156" rx="2" class="ep__sheen"/>
      <text x="30" y="110" dominant-baseline="central"
            {% if _mode == 'single' %}data-engrave-preview{% else %}data-set-preview="necklace"{% endif %}
            data-fit="140" data-fit-chars="12" lengthAdjust="spacingAndGlyphs"
            class="ep__engrave-text ep__engrave-text--vertical"
            data-placeholder="{{ placeholder | escape }}">{{ placeholder }}</text>
    </svg>

  {%- when 'ring' -%}
    <svg viewBox="0 0 220 140" class="ep__set-svg ep__set-svg--ring" aria-hidden="true">
      <ellipse cx="110" cy="70" rx="95" ry="55" fill="none" stroke="#23232a" stroke-width="18" class="ep__ring-band"/>
      <ellipse cx="110" cy="70" rx="95" ry="55" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="16"/>
      <defs><path id="{{ id_prefix }}-ring-text" d="M 15,70 A 95,55 0 0 1 205,70" fill="none"/></defs>
      <text class="ep__engrave-text ep__engrave-text--curve">
        <textPath href="#{{ id_prefix }}-ring-text" startOffset="50%" text-anchor="middle"
                  {% if _mode == 'single' %}data-engrave-preview{% else %}data-set-preview="ring"{% endif %}
                  data-fit="200" data-fit-chars="20" lengthAdjust="spacingAndGlyphs"
                  data-placeholder="{{ placeholder | escape }}">{{ placeholder }}</textPath>
      </text>
    </svg>

  {%- when 'keychain' -%}
    <svg viewBox="0 0 120 200" class="ep__set-svg ep__set-svg--keychain" aria-hidden="true">
      <circle cx="60" cy="22" r="16" fill="none" class="ep__chain-line" stroke-width="3.5"/>
      <line x1="60" y1="38" x2="60" y2="50" class="ep__chain-line" stroke-width="2"/>
      <rect x="24" y="54" width="72" height="116" rx="8" class="ep__metal"/>
      <rect x="27" y="57" width="22" height="110" rx="6" class="ep__sheen"/>
      <circle cx="60" cy="68" r="5" class="ep__hole"/>
      <text x="60" y="122"
            {% if _mode == 'single' %}data-engrave-preview{% else %}data-set-preview="keychain"{% endif %}
            data-fit="86" data-fit-chars="9" lengthAdjust="spacingAndGlyphs"
            class="ep__engrave-text ep__engrave-text--vertical"
            data-placeholder="{{ placeholder | escape }}">{{ placeholder }}</text>
    </svg>

{%- endcase -%}
