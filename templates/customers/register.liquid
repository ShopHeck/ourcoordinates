<section class="section"><div class="page-width page-narrow">
<h1>Create account</h1>
{% form 'create_customer' %}
  <p><input type="text" name="customer[first_name]" placeholder="First name" style="width:100%;padding:12px;border:1px solid var(--c-line)"></p>
  <p><input type="text" name="customer[last_name]" placeholder="Last name" style="width:100%;padding:12px;border:1px solid var(--c-line)"></p>
  <p><input type="email" name="customer[email]" placeholder="Email" required style="width:100%;padding:12px;border:1px solid var(--c-line)"></p>
  <p><input type="password" name="customer[password]" placeholder="Password" required style="width:100%;padding:12px;border:1px solid var(--c-line)"></p>
  <button type="submit" class="btn">Create account</button>
{% endform %}
</div></section>
