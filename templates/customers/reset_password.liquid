<section class="section"><div class="page-width page-narrow">
<h1>Reset password</h1>
{% form 'reset_customer_password' %}
  <p><input type="password" name="customer[password]" placeholder="New password" required style="width:100%;padding:12px;border:1px solid var(--c-line)"></p>
  <p><input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required style="width:100%;padding:12px;border:1px solid var(--c-line)"></p>
  <button type="submit" class="btn">Reset password</button>
{% endform %}
</div></section>
