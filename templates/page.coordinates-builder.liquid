        // ===== RENDER SVGS DYNAMICALLY WITH CUSTOM ENGRAVING =====
        function renderQuizThumbnails() {
            // Renders static thumbnail versions for Step 4 selector cards
            document.getElementById('quiz-svg-round-charm').innerHTML = generateSvgMarkup('round-charm', 'gold', '40.3923° N, 74.9711° W', 'FOREVER');
