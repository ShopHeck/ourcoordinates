                    className: 'custom-map-pin',
                    html: '<div style="background-color: #C5A880; width: 18px; height: 18px; border-radius: 50%; border: 3px solid #0A1128; box-shadow: 0 4px 10px rgba(0,0,0,0.3); transform: scale(1.2);"></div>',
                    iconSize: [18, 18],
                    iconAnchor: [9, 9]
                });
                
                // Set up initial marker center
                mapMarker = L.marker([27.7712, -82.6340], {
                    draggable: true,
                    icon: goldPinIcon
                }).addTo(leafletMap);
                
                mapMarker.on('dragend', function() {
                    const position = mapMarker.getLatLng();
                    updateCoordinates(position.lat, position.lng);
                });
                
                // Force recalculate dimensions since container may have transition styles
                setTimeout(() => {
                    leafletMap.invalidateSize();
                }, 200);
            } catch (err) {
                console.warn("Leaflet failed to initialize (likely due to offline or sandbox restrictions):", err);
