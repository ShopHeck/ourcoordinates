        async function performSearch() {
            const query = document.getElementById('locationInput').value.trim();
            if (query.length < 3) {
                alert('Please enter a location with at least 3 letters.');
                return;
            }
            
            const loader = document.getElementById('searchLoading');
            const errorBox = document.getElementById('searchError');
            loader.classList.add('visible');
            errorBox.style.display = 'none';
            
            try {
                // Fetch coordinates from free Nominatim geocoder (OpenStreetMap)
                const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`;
                const response = await fetch(url, {
                    headers: { 'Accept-Language': 'en' }
                });
                
                if (!response.ok) throw new Error('Geocoding search failed');
                
                const results = await response.json();
                
                if (results && results.length > 0) {
                    const result = results[0];
                    const lat = parseFloat(result.lat);
                    const lon = parseFloat(result.lon);
                    
                    // Center map and marker on location
                    leafletMap.setView([lat, lon], 14);
                    mapMarker.setLatLng([lat, lon]);
                    
                    // Enable drag helper and sync coords
                    document.getElementById('mapDragHelper').classList.add('visible');
                    updateCoordinates(lat, lon);
                } else {
                    errorBox.style.display = 'block';
                }
            } catch (err) {
                console.error(err);
                errorBox.style.display = 'block';
            } finally {
                loader.classList.remove('visible');
            }
        }

        function updateCoordinates(lat, lon) {
            const latDir = lat >= 0 ? 'N' : 'S';
            const lonDir = lon >= 0 ? 'E' : 'W';
            const formattedString = `${Math.abs(lat).toFixed(4)}° ${latDir}, ${Math.abs(lon).toFixed(4)}° ${lonDir}`;
            
            quizData.coordinates = formattedString;
            
            const display = document.getElementById('coordinatesDisplay');
            display.textContent = formattedString;
            display.classList.add('visible');
            
            document.getElementById('step1Next').disabled = false;
        }

