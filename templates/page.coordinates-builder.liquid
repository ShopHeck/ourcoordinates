        .word-preview {
            text-align: center;
            margin-top: 32px;
            padding: 32px;
            background: var(--white);
            border-radius: 16px;
            border: 2px dashed var(--gold);
            display: none;
        }

        .word-preview.visible {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        .word-preview-label {
            font-family: 'Outfit', sans-serif;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-light);
            margin-bottom: 12px;
            font-weight: 500;
        }

        .word-preview-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 40px;
            font-weight: 600;
            color: var(--navy);
            font-style: italic;
            letter-spacing: 1.5px;
        }

        /* EMAIL GATE STYLING */
        .email-gate {
            text-align: center;
            padding: 24px 0;
        }

        .email-gate h2 {
            font-family: 'Outfit', sans-serif;
            font-size: 32px;
            color: var(--navy);
            margin-bottom: 12px;
        }

        .email-gate p {
            font-size: 16px;
            color: var(--text-light);
            max-width: 440px;
            margin: 0 auto 32px;
        }

        .blurred-preview {
            background: linear-gradient(135deg, #FFF, #ECE8E2);
            border-radius: 20px;
            padding: 60px 40px;
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border);
            box-shadow: 0 8px 30px rgba(0,0,0,0.03);
        }

        .blur-overlay {
            position: absolute;
