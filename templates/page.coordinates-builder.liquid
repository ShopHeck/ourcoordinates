        function initializeLeafletMap() {
            if (leafletMap) return;
            
            // Set default coordinates so the user is never blocked, even if Leaflet fails to load
            updateCoordinates(27.7712, -82.6340);
            
            try {
                if (typeof L === 'undefined') {
                    throw new Error('Leaflet library is not loaded.');
                }
                
                // Create map div if placeholder is active
                const mapContainer = document.getElementById('mapPreview');
                document.getElementById('mapPlaceholder').style.display = 'none';
                
                // Initialize Leaflet with clean minimalist CartoDB Positron tiles
