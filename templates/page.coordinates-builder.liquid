                    zoomControl: true,
                    attributionControl: false,
                    scrollWheelZoom: false
                }).setView([27.7712, -82.6340], 13); // Center on default coordinates
                
                L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                    maxZoom: 19
                }).addTo(leafletMap);
                
                // Custom gold/navy marker pin
