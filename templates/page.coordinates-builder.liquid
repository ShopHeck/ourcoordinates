            document.getElementById('quiz-svg-horizontal-bar').innerHTML = generateSvgMarkup('horizontal-bar', 'gold', '40.3923° N, 74.9711° W', 'FOREVER');
        }

        function generateSvgMarkup(style, metal, coords, word) {
            let svg = SVG_TEMPLATES[style];
            
            // Adjust metal gradients
            svg = svg.replace(/fill="url\(#gold\)"/g, `fill="url(#${metal})"`);
            svg = svg.replace(/stroke="url\(#gold\)"/g, `stroke="url(#${metal})"`);
            
            const metalChainColors = {
                gold: '#d2a04a',
                silver: '#c8ccd0',
                rose: '#d28a72'
            };
            
            const chainColor = metalChainColors[metal];
            const engravingColor = metal === 'silver' ? '#3C434A' : '#503c25';
            
            // Inject overrides styles to customize the SVG dynamically
            const overrideStyle = `
                <style>
                    .chain, .chain-silver { stroke: ${chainColor} !important; fill: none !important; }
                    .engraving { fill: ${engravingColor} !important; font-family: Avenir, Helvetica, Arial, sans-serif !important; font-weight: 700 !important; filter: url(#engraveInset) !important; }
                    .metal-stroke { stroke: rgba(255,255,255,0.66) !important; }
                    .bg { fill: transparent !important; }
                </style>
            `;
            svg = svg.replace('<g', `${overrideStyle}<g`);
            svg = svg.replace('--chain-color', chainColor); // Special case for round charm custom inline SVG
            
            // Insert coordinates and words on surfaces/paths
            const parser = new DOMParser();
            const doc = parser.parseFromString(svg, 'image/svg+xml');
            const svgElement = doc.documentElement;
            
            const surface = svgElement.querySelector('#engravingSurface');
            const path = svgElement.querySelector('#engravingPath');
            
            const lat = coords.split(',')[0].trim();
            const lng = coords.split(',')[1] ? coords.split(',')[1].trim() : '';
            
            if (path) {
                // Curve text placement
                const textNode = doc.createElementNS('http://www.w3.org/2000/svg', 'text');
                textNode.setAttribute('class', 'engraving');
                textNode.setAttribute('dy', style === 'ring' ? '12' : '10');
                textNode.setAttribute('font-size', '20px');
                textNode.setAttribute('letter-spacing', '1px');
                
                const textPathNode = doc.createElementNS('http://www.w3.org/2000/svg', 'textPath');
                textPathNode.setAttribute('href', '#' + path.id);
                textPathNode.setAttribute('startOffset', '50%');
                textPathNode.setAttribute('text-anchor', 'middle');
                textPathNode.textContent = `${lat} ${lng}${word ? ' • ' + word : ''}`;
                
                textNode.appendChild(textPathNode);
                path.parentNode.insertBefore(textNode, path.nextSibling);
            } else if (surface) {
                // Rectangular flat coordinates placement
                const textNode = doc.createElementNS('http://www.w3.org/2000/svg', 'text');
                textNode.setAttribute('class', 'engraving');
                textNode.setAttribute('text-anchor', 'middle');
                
                if (style === 'round-charm') {
                    // Custom layout for round charm circular pendant
                    textNode.setAttribute('x', '100');
                    textNode.setAttribute('y', word ? '98' : '101');
                    textNode.setAttribute('font-size', '8px');
                    textNode.setAttribute('letter-spacing', '0.5px');
                    
                    const tspan1 = doc.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                    tspan1.setAttribute('x', '100');
                    tspan1.setAttribute('dy', '0');
                    tspan1.textContent = lat;
                    
                    const tspan2 = doc.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                    tspan2.setAttribute('x', '100');
                    tspan2.setAttribute('dy', '11');
                    tspan2.textContent = lng;
                    
                    textNode.appendChild(tspan1);
                    textNode.appendChild(tspan2);
                    
                    if (word) {
                        const tspan3 = doc.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                        tspan3.setAttribute('x', '100');
                        tspan3.setAttribute('dy', '18');
                        tspan3.setAttribute('font-style', 'italic');
                        tspan3.setAttribute('font-size', '7.5px');
                        tspan3.textContent = word;
                        textNode.appendChild(tspan3);
                    }
                    
                    surface.parentNode.appendChild(textNode);
                } else {
                    // Standard horizontal/vertical bar layout
                    const rectX = parseFloat(surface.getAttribute('x'));
                    const rectY = parseFloat(surface.getAttribute('y'));
                    const rectW = parseFloat(surface.getAttribute('width'));
                    const rectH = parseFloat(surface.getAttribute('height'));
                    
                    const centerX = rectX + rectW / 2;
                    const centerY = rectY + rectH / 2;
                    
                    textNode.setAttribute('x', centerX);
                    textNode.setAttribute('font-size', '20px');
                    
                    if (word && rectH >= 80) {
                        // 2-Line engraving layout
                        textNode.setAttribute('y', centerY + 4);
                        
                        const tspan1 = doc.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                        tspan1.setAttribute('x', centerX);
                        tspan1.setAttribute('dy', '-5');
                        tspan1.textContent = `${lat} ${lng}`;
                        
                        const tspan2 = doc.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                        tspan2.setAttribute('x', centerX);
                        tspan2.setAttribute('dy', '32');
                        tspan2.setAttribute('font-size', '16px');
                        tspan2.setAttribute('font-style', 'italic');
                        tspan2.textContent = word;
                        
                        textNode.appendChild(tspan1);
                        textNode.appendChild(tspan2);
                    } else {
                        // 1-Line simple coordinate layout
                        textNode.setAttribute('y', centerY + 8);
                        textNode.textContent = `${lat} ${lng}${word ? ' • ' + word : ''}`;
                    }
                    surface.parentNode.insertBefore(textNode, surface.nextSibling);
                }
            }
            
            return new XMLSerializer().serializeToString(svgElement);
        }

        // ===== SHOW RESULTS =====
        function handleEmailKeyPress(e) {
            if (e.key === 'Enter') {
                revealResults();
            }
        }

        function revealResults() {
            const email = document.getElementById('emailInput').value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                alert('Please enter a valid email address.');
                return;
            }
            
            emailSubmitted = true;
            
            // Submit email to Shopify in the background
            submitLeadToShopify(email);
            
            document.getElementById('quizContainer').style.display = 'none';
            document.getElementById('resultsPage').classList.add('active');
            
            renderResultsData();
        }

        async function submitLeadToShopify(email) {
            // Post email to Shopify's native Customer newsletter endpoint programmatically
            const payload = new FormData();
            payload.append('form_type', 'customer');
            payload.append('utf8', '✓');
            payload.append('contact[tags]', 'newsletter, Coordinate Story Lead Magnet');
            payload.append('contact[email]', email);
            
            try {
                // Send request in background. no-cors bypasses cross-origin redirect blocks
                await fetch('/contact', {
                    method: 'POST',
                    body: payload,
                    mode: 'no-cors'
                });
                console.log("Customer email lead registered in Shopify database.");
            } catch (e) {
                console.error("Lead fetch failed, moving forward:", e);
            }
        }

        function renderResultsData() {
            if (!emailSubmitted) return;
            const archetype = archetypes[quizData.storyType] || archetypes['first-date'];
            const coords = quizData.coordinates || '40.3923° N, 74.9711° W';
            const word = quizData.word !== undefined ? quizData.word : 'FOREVER';
            const dateStr = quizData.date ? 'Est. ' + new Date(quizData.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Your Coordinates';
            
            // Populating story card values
            document.getElementById('storyIcon').textContent = archetype.icon;
            document.getElementById('resultCoordinates').textContent = coords;
            const wordElement = document.getElementById('resultWord');
            if (word) {
                wordElement.textContent = word;
                wordElement.style.display = 'block';
            } else {
                wordElement.textContent = '';
                wordElement.style.display = 'none';
            }
            document.getElementById('resultDate').textContent = dateStr;
            
            document.getElementById('resultsHeadline').textContent = archetype.headline;
            document.getElementById('resultsSubheadline').textContent = archetype.subheadline;
            
            // Set word input value
            const wordInput = document.getElementById('resultWordInput');
            if (wordInput) {
                wordInput.value = word;
            }
            
            // Set remove button label and style
            const removeBtn = document.getElementById('removeTextBtn');
            if (removeBtn) {
                if (word) {
                    removeBtn.textContent = 'Remove';
                    removeBtn.className = 'control-btn danger';
                } else {
                    removeBtn.textContent = 'Add Text';
                    removeBtn.className = 'control-btn';
                }
            }
            
            updatePreviewProducts();
            
            // Render Reviews
            const reviewsContainer = document.getElementById('reviewContainer');
            reviewsContainer.innerHTML = '';
            archetype.reviews.forEach(rev => {
                const card = document.createElement('div');
                card.className = 'review-card';
                card.innerHTML = `
                    <div class="review-text">"${rev.text}"</div>
                    <div class="review-author">— ${rev.author}</div>
                `;
                reviewsContainer.appendChild(card);
            });
            
            startCountdownTimer();
        }

        function updatePreviewProducts() {
            const archetype = archetypes[quizData.storyType] || archetypes['first-date'];
            const coords = quizData.coordinates || '40.3923° N, 74.9711° W';
            const word = quizData.word !== undefined ? quizData.word : 'FOREVER';
            const grid = document.getElementById('productGrid');
            grid.innerHTML = '';
            
            // Remap primary product type to match selected style from step 4
            const updatedProducts = archetype.products.map((p, index) => {
                if (index === 0) {
                    return {
                        ...p,
                        type: quizData.necklaceStyle,
                        name: ShopifyConfig[quizData.necklaceStyle].name
                    };
                }
                return p;
            });
            
            // Set engraving note style text
            const styleNames = {
                'round-charm': 'Round Charm Pendant',
                'vertical-bar': '4-Sided Vertical Bar',
                'horizontal-bar': 'Horizontal Bar',
                'cuff-bracelet': 'Cuff Bracelet',
                'ring': 'Flat Band Ring',
                'keychain': 'Keychain'
            };
            const metalNames = { gold: 'Gold', silver: 'Silver', rose: 'Rose Gold' };
            
            document.getElementById('engravingNote').innerHTML = `👆 <strong>Below is your ${styleNames[quizData.necklaceStyle]} style</strong> in <strong>${metalNames[quizData.metal]}</strong> with realistic engraved coordinates. Every piece is <strong>hand-engraved</strong> in our USA workshop with your exact coordinates and word.`;
            
            updatedProducts.forEach(prod => {
                const svgMarkup = generateSvgMarkup(prod.type, quizData.metal, coords, word);
                const card = document.createElement('div');
                card.className = 'product-card' + (prod.featured ? ' featured' : '');
                
                card.innerHTML = `
                    <div class="product-preview">
                        ${prod.featured ? `<div class="product-badge">Built For Your Story</div>` : ''}
                        ${svgMarkup}
                    </div>
                    <div class="product-info">
                        <div class="product-label">${prod.label}</div>
                        <div class="product-name">${prod.name}</div>
                        <div class="product-price">${prod.price} <span class="original">${prod.original}</span></div>
                        <div class="product-description">${prod.description}</div>
                        ${prod.type === 'ring' ? `
                            <div class="ring-size-wrapper" style="margin-top: -5px; margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between; background: rgba(10, 17, 40, 0.03); padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(10, 17, 40, 0.08);">
                                <span style="font-size: 13px; font-weight: 500; color: var(--navy);">Select Ring Size:</span>
                                <select id="ringSizeSelect" onchange="updateRingSize(this.value)" style="padding: 6px 12px; border-radius: 4px; border: 1px solid rgba(10, 17, 40, 0.15); background: white; font-family: 'Outfit', sans-serif; font-size: 13px; color: var(--navy); font-weight: 600; cursor: pointer; outline: none;">
                                    <option value="5" ${quizData.ringSize === '5' ? 'selected' : ''}>Size 5</option>
                                    <option value="6" ${quizData.ringSize === '6' ? 'selected' : ''}>Size 6</option>
                                    <option value="7" ${quizData.ringSize === '7' ? 'selected' : ''}>Size 7</option>
                                    <option value="8" ${quizData.ringSize === '8' ? 'selected' : ''}>Size 8</option>
                                    <option value="9" ${quizData.ringSize === '9' ? 'selected' : ''}>Size 9</option>
                                    <option value="10" ${quizData.ringSize === '10' ? 'selected' : ''}>Size 10</option>
                                </select>
                            </div>
                        ` : ''}
                        <button class="btn ${prod.featured ? 'btn-primary' : 'btn-teal'} btn-full" onclick="addSingleProductToCart('${prod.type}')">
                            ${prod.featured ? 'Add to Cart — 20% Off' : 'Add to Cart'}
                        </button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        // ===== METAL SELECTION TOGGLE =====
        function switchMetal(metal) {
            quizData.metal = metal;
            
            // Toggle active classes on selectors
            document.querySelectorAll('.metal-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelector(`.metal-btn-${metal}`).classList.add('active');
            
            updatePreviewProducts();
        }

        function updateRingSize(val) {
            quizData.ringSize = val;
        }

        // ===== ADD TO CART (SHOPIFY INTEGRATION) =====
        function addFeaturedToCart() {
            addSingleProductToCart(quizData.necklaceStyle);
        }

        async function addSingleProductToCart(styleType) {
            const metal = quizData.metal;
            const coords = quizData.coordinates || '40.3923° N, 74.9711° W';
            const word = quizData.word !== undefined ? quizData.word : 'FOREVER';
            
            // Map selected style/metal to variant ID
            const variantsMap = ShopifyConfig[styleType] || ShopifyConfig['round-charm'];
            
            let variantId;
            let selectedSize = '';
            if (styleType === 'ring') {
                selectedSize = quizData.ringSize || '7';
                const ringMetalMap = variantsMap[metal] || variantsMap.gold;
                variantId = ringMetalMap[selectedSize] || ringMetalMap['7'];
            } else {
                variantId = variantsMap[metal] || variantsMap.gold;
            }
            
            const productName = variantsMap.name;
            
            // Properties list that Shopify order panel displays
            const itemProperties = {
                'Coordinates': coords,
                'Engraving Word': word || 'None',
                'Metal': metal.charAt(0).toUpperCase() + metal.slice(1),
                '_source': 'Coordinate Lead Magnet Builder'
            };
            if (selectedSize) {
                itemProperties['Size'] = selectedSize;
            }
            
            try {
                // Post to Shopify's Add to Cart Endpoint
                const response = await fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id: variantId,
                        quantity: 1,
                        properties: itemProperties
                    })
                });
                
                if (!response.ok) throw new Error('Shopify ajax add to cart failed');
                
                // Redirect user directly to checkout page for highest conversion rates
                window.location.href = '/checkout';
            } catch (err) {
                console.error(err);
                
                // Fallback permalink in case builder is hosted on a separate custom domain
                const sizeParam = selectedSize ? `&properties[Size]=${encodeURIComponent(selectedSize)}` : '';
                const permalink = `/cart/${variantId}:1?properties[Coordinates]=${encodeURIComponent(coords)}&properties[Engraving]=${encodeURIComponent(word || 'None')}&properties[Metal]=${encodeURIComponent(metal)}${sizeParam}`;
                window.location.href = permalink;
            }
        }

        // ===== COUNTDOWN TIMER =====
        function startCountdownTimer() {
            let hr = 47, min = 59, sec = 59;
            const timer = setInterval(() => {
                if (sec > 0) sec--;
                else if (min > 0) { min--; sec = 59; }
                else if (hr > 0) { hr--; min = 59; sec = 59; }
                else { clearInterval(timer); document.getElementById('countdownTimer').textContent = 'EXPIRED'; return; }
                
                document.getElementById('countdownTimer').textContent = 
                    `${hr.toString().padStart(2, '0')}:${min.toString().padStart(2, '0')}:${sec.toString().padStart(2, '0')}`;
            }, 1000);
        }

        // ===== CANVAS IMAGE DOWNLOAD =====
        function downloadStoryCard() {
            const canvas = document.createElement('canvas');
            canvas.width = 800;
            canvas.height = 500;
            const ctx = canvas.getContext('2d');
            
            // Background gradient
            const grad = ctx.createLinearGradient(0, 0, 800, 500);
            grad.addColorStop(0, '#FAFAF8');
            grad.addColorStop(1, '#F4EFE6');
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, 800, 500);
            
            // Gold border strip at top
            ctx.fillStyle = '#C5A880';
            ctx.fillRect(0, 0, 800, 8);
            
            // Icon
            ctx.font = '72px Arial';
            ctx.textAlign = 'center';
            ctx.fillText(document.getElementById('storyIcon').textContent, 400, 110);
            
            // Coordinates
            ctx.font = 'bold 26px "Courier New", monospace';
            ctx.fillStyle = '#0A1128';
            ctx.fillText(document.getElementById('resultCoordinates').textContent, 400, 180);
            
            // Word
            const wordVal = document.getElementById('resultWord').textContent.trim();
            if (wordVal) {
                ctx.font = 'italic bold 36px "Cormorant Garamond", Georgia, serif';
                ctx.fillStyle = '#C5A880';
                ctx.fillText(wordVal, 400, 240);
                
                // Date
                ctx.font = '600 13px "Outfit", sans-serif';
                ctx.fillStyle = '#606870';
                ctx.fillText(document.getElementById('resultDate').textContent, 400, 280);
            } else {
                // If there's no word, center the date in the space
                ctx.font = '600 14px "Outfit", sans-serif';
                ctx.fillStyle = '#606870';
                ctx.fillText(document.getElementById('resultDate').textContent, 400, 245);
            }
            
            // Decorative Divider lines
            ctx.beginPath();
            ctx.moveTo(350, 330);
            ctx.lineTo(450, 330);
            ctx.strokeStyle = '#E5E8EB';
            ctx.lineWidth = 1.5;
            ctx.stroke();
            
            // Watermark brand
            ctx.font = '600 11px "Outfit", sans-serif';
            ctx.fillStyle = '#A0AAB5';
            ctx.fillText('OURCOORDINATES — YOUR STORY, WORN', 400, 440);
            
            // Trigger browser download anchor link
            const anchor = document.createElement('a');
            anchor.download = 'ourcoordinates-my-story-card.png';
            anchor.href = canvas.toDataURL();
            anchor.click();
        }

        function updateEngravingText(val) {
            const cleanVal = val.toUpperCase().trim();
            quizData.word = cleanVal;
            
            // Sync with results page data
            const wordElement = document.getElementById('resultWord');
            if (wordElement) {
                if (cleanVal) {
                    wordElement.textContent = cleanVal;
                    wordElement.style.display = 'block';
                } else {
                    wordElement.textContent = '';
                    wordElement.style.display = 'none';
                }
            }
            
            // Sync input button text/style
            const removeBtn = document.getElementById('removeTextBtn');
            if (removeBtn) {
                if (cleanVal) {
                    removeBtn.textContent = 'Remove';
                    removeBtn.className = 'control-btn danger';
                } else {
                    removeBtn.textContent = 'Add Text';
                    removeBtn.className = 'control-btn';
                }
            }
            
            // Re-render mockups
            updatePreviewProducts();
        }

        function removeEngravingText() {
            const input = document.getElementById('resultWordInput');
            
            if (quizData.word) {
                // Remove the word
                input.value = '';
                updateEngravingText('');
            } else {
                // Focus the input to add text
                input.focus();
            }
        }

        // Hide quiz container on load
        document.getElementById('quizContainer').style.display = 'none';
    </script>
</body>
</html>